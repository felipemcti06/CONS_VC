# --------------------------------------------------------------------------------------------
# Name Accounts Receivable
# Desc Accounts Receivable
# Date 02/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.D.Accounts_WC':'Accounts Receivable','DFS.M.160.Working_Capital':'DFS.M.160.Working_Capital':'Value'] = N:
  DB('STG.100.DataBase_Uploads', 
          !ALL.D.Year, 
          !ALL.D.Month, 
          !ALL.D.Version, 
          !ALL.D.Currency, 
          !ALL.D.Region, 
           'ALL.D.Products':'Total Products', 
           'Account Receivable - Days o/ Rev',
           'ALL.D.Account_Line':'Total Accounts Line', 
           'Value' ) 
    \
  DB( 'ALL.010.Economic_Assumptions', 
            !ALL.D.Year, 
            !ALL.D.Month, 
            !ALL.D.Version, 
            'Number of Days',
            'Value' )
  * 
  DB('REV.100.Revenue_Consolidated', 
           !ALL.D.Year,
           !ALL.D.Month, 
           !ALL.D.Version, 
           !ALL.D.Currency, 
           !ALL.D.Region, 
           'ALL.D.Products':'Total Products', 
           'ALL.D.Market':'Total Market', 
            'Gross Revenue [$MM]' );


