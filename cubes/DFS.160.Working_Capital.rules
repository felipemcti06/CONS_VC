# --------------------------------------------------------------------------------------------
# Name Initial Working Capital Balance
# Desc Initial Working Capital Balance
# Date 02/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 ['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'WKC.030.001','DFS.M.160.Working_Capital':'Value'] = N:

         DB('STG.100.DataBase_Uploads', 
          !ALL.D.Year, 
          !ALL.D.Month, 
          !ALL.D.Version, 
          !ALL.D.Currency, 
          !ALL.D.Region, 
           'ALL.D.Products':'Total Products', 
           'WKC.030.001',
           'ALL.D.Account_Line':'Total Accounts Line', 
           'Value' ) 
  +

   DB( 'DFS.160.Working_Capital',
      DB( 'SYS.200.Time_Travel', !ALL.D.Year, !ALL.D.Month, '-1', 'Ano' )  ,
      DB( 'SYS.200.Time_Travel', !ALL.D.Year, !ALL.D.Month, '-1', 'Mes' ) ,
       !ALL.D.Version,
       !ALL.D.Currency,
       !ALL.D.Region,
       'Working Capital',
       'DFS.M.160.Working_Capital':'Total Value'
     )
;

# --------------------------------------------------------------------------------------------
# Name Working Capital'
# DescWorking Capital'
# Date 02/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 ['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'Working Capital'] = N:

DB( 'DFS.160.Working_Capital', 
    !ALL.D.Year,
    !ALL.D.Month,
    !ALL.D.Version,
    !ALL.D.Currency,
    !ALL.D.Region,
    'DFS.D.Accounts_WC':'PROJECTED BALANCE - ASSETS',
    !DFS.M.160.Working_Capital 
  )
   -
 DB( 'DFS.160.Working_Capital', 
    !ALL.D.Year,
    !ALL.D.Month,
    !ALL.D.Version,
    !ALL.D.Currency,
    !ALL.D.Region,
    'DFS.D.Accounts_WC':'PROJECTED BALANCE - LIABILITIES',
    !DFS.M.160.Working_Capital 
  )  
   ;


# --------------------------------------------------------------------------------------------
# Name (Invest.)/Divest. Working Capital
# Desc (Invest.)/Divest. Working Capital
# Date 02/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 ['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'(Invest.)/Divest. Working Capital'] = N:

['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'WKC.030.001']
   -
 ['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'Working Capital'] 
   
   +
  ['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'WC adjust by buy/sale of company'] 
  
   ;
# --------------------------------------------------------------------------------------------
# Name Cash Conversion Cycle
# Desc Cash Conversion Cycle
# Date 02/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 ['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'Cash Conversion Cycle'] =

['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'Account Receivable - Days o/ Rev']
   +
 ['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'WKC.010.007'] 
   
   -
  ['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'Suppliers - Days o/ VC'] 
  
   ;
# --------------------------------------------------------------------------------------------
#
#                      			INICIO DO BLOCO DE FEEDERS
#
# --------------------------------------------------------------------------------------------

# =============
  FEEDERS;
# =============
# # --------------------------------------------------------------------------------------------
# # Name: Feedes Forecast 
# # Desc: Feedes Forecast 
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
 ['ALL.D.Version':'ALL.D.Version':'RE'] => ['ALL.D.Version':'ALL.D.Version':'Dynamic Versions'];


    
# --------------------------------------------------------------------------------------------
# Name: ConversÃ£o de Moedas
# Desc: ConversÃ£o de moedas para os padrÃµes USD, BRL e EUR
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
[ 'DFS.M.160.Working_Capital':'DFS.M.160.Working_Capital':'Adjustments','ALL.D.Currency':'ALL.D.Currency':'Total Currency','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'DFS.160.Working_Capital', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'BRL Conv.', !ALL.D.Region, !DFS.D.Accounts_WC, 'Adjustments' ),
  DB( 'DFS.160.Working_Capital', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'EUR Conv.', !ALL.D.Region, !DFS.D.Accounts_WC, 'Adjustments' ),
  DB( 'DFS.160.Working_Capital', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'USD Conv.', !ALL.D.Region, !DFS.D.Accounts_WC, 'Adjustments' )
    
    
    ;

# --------------------------------------------------------------------------------------------
# Name: Working Capital
# Desc: Working Capital
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'Working Capital'
 ,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=> 
DB( 'DFS.160.Working_Capital',
    DB( 'SYS.200.Time_Travel', !ALL.D.Year, !ALL.D.Month, '1', 'Ano' )  ,
    DB( 'SYS.200.Time_Travel', !ALL.D.Year, !ALL.D.Month, '1', 'Mes' ) ,
    !ALL.D.Version,
    !ALL.D.Currency,
    !ALL.D.Region,
    'WKC.030.001',
    !DFS.M.160.Working_Capital );



# --------------------------------------------------------------------------------------------
# Name: Working Capital
# Desc: Working Capital
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'PROJECTED BALANCE - ASSETS',
'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'Working Capital'];

['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'PROJECTED BALANCE - LIABILITIES',
'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'Working Capital'];


# --------------------------------------------------------------------------------------------
# Name: (Invest.)/Divest. Working Capital
# Desc: (Invest.)/Divest. Working Capital'
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'WKC.030.001',
'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'(Invest.)/Divest. Working Capital'];

['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'Working Capital',
'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'(Invest.)/Divest. Working Capital'];

['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'WC adjust by buy/sale of company',
'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'(Invest.)/Divest. Working Capital'];

# --------------------------------------------------------------------------------------------
# Name: Cash Conversion Cycle
# Desc: Cash Conversion Cycle
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'Account Receivable - Days o/ Rev',
'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'Cash Conversion Cycle'];

['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'WKC.010.007',
'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'Cash Conversion Cycle'];

['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'Suppliers - Days o/ VC',
'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'Cash Conversion Cycle'];    

