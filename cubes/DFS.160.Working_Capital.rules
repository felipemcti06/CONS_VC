# --------------------------------------------------------------------------------------------
['DFS.D.Accounts_WC':'DFS.D.Accounts_WC':'(Invest.)/Divest. Working Capital',
'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'DFS.140.Indirect_Cash_Flow', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, 'Working capital', !DFS.M.160.Working_Capital);


