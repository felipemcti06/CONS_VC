# --------------------------------------------------------------------------------------------
 ['DFS.D.Accounts_WC':'Other Accounts Payable','DFS.M.160.Working_Capital':'Value'] = N:
      DB('STG.100.DataBase_Uploads', 
          !ALL.D.Year, 
          !ALL.D.Month, 
          !ALL.D.Version, 
          !ALL.D.Currency, 
          !ALL.D.Region, 
           'ALL.D.Products':'Total Products', 
           'Other Accounts Payable - Days o/ CPS',
           'ALL.D.Account_Line':'Total Accounts Line', 
           'Value' ) 

    \
  DB( 'ALL.010.Economic_Assumptions', 
            !ALL.D.Year, 
            !ALL.D.Month, 
            !ALL.D.Version, 
            'Number of Days',
            'Value' )  
   *
 (   DB('STG.100.DataBase_Uploads', 
          !ALL.D.Year, 
          !ALL.D.Month, 
          !ALL.D.Version, 
          !ALL.D.Currency, 
          !ALL.D.Region, 
           'ALL.D.Products':'Total Products', 
           'CST.010.001',
           'ALL.D.Account_Line':'Total Accounts Line', 
           'Value' ) 
   +
       DB('STG.100.DataBase_Uploads', 
          !ALL.D.Year, 
          !ALL.D.Month, 
          !ALL.D.Version, 
          !ALL.D.Currency, 
          !ALL.D.Region, 
           'ALL.D.Products':'Total Products', 
           'CST.020.001',
           'ALL.D.Account_Line':'Total Accounts Line', 
           'Value' )
     );   

