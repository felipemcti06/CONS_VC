['SYS.M.910.Version_Copy_Cube':'Dimension Year and Month'] =S:
IF (     DB('SYS.910.Version_Copy_Cube',!SYS.D.Cube,'Dimension Year') @<> ''
      % DB('SYS.910.Version_Copy_Cube',!SYS.D.Cube,'Dimension Month') @<> ''
	,''
	,STET
);

['SYS.M.910.Version_Copy_Cube':{'Copy Version (Y/N)','Copy Version(Y/N) Scenario 1','Copy Version(Y/N) Scenario 2','Copy Version(Y/N) Scenario 3'}]   =S:
 IF(    DB('SYS.910.Version_Copy_Cube',ELPAR('SYS.D.Cube',!SYS.D.Cube,1),!SYS.M.910.Version_Copy_Cube) @<>''
               , DB('SYS.910.Version_Copy_Cube',ELPAR('SYS.D.Cube',!SYS.D.Cube,1),!SYS.M.910.Version_Copy_Cube)
               ,STET
 );