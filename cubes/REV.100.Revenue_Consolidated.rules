# --------------------------------------------------------------------------------------------
['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Net Revenue [$MM]','ALL.D.Market':'ALL.D.Market':'Total Market','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'DFS.100.Profit_and_Loss', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'Net Revenue', 'Value' );

