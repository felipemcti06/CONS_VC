  FEEDERS;
# =============
# # --------------------------------------------------------------------------------------------
# # Name: Feedes Forecast 
# # Desc: Feedes Forecast 
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
 ['ALL.D.Version':'ALL.D.Version':'RE'] => ['ALL.D.Version':'ALL.D.Version':'Dynamic Versions'];


# --------------------------------------------------------------------------------------------
# Name:Net Revenue [$MM]
# Desc: Net Revenue [$MM]
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 
['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Sales Volume [kt]','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=> ['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Net Revenue [$MM]' ] ; 

['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Reference Price [$/ton]','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=> ['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Net Revenue [$MM]' ] ; 

['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Price Premium [$/ton]','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=> ['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Net Revenue [$MM]' ] ;    
# --------------------------------------------------------------------------------------------
# Name:Gross Revenue [$MM]'
# Desc:Gross Revenue [$MM]'
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 
['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Sales Volume [kt]','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=> ['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Gross Revenue [$MM]' ] ; 

