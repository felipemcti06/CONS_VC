# =============
  SKIPCHECK;
  FEEDSTRINGS;
# =============
# --------------------------------------------------------------------------------------------
# Name:Price Premium [$/ton]
# Desc: Price Premium [$/ton]
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------

  ['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Price Premium [$/ton]'] = 
        IF( DTYPE( 'ALL.D.Month', !ALL.D.Month )@='C' 
       % DTYPE( 'ALL.D.Products', !ALL.D.Products )@='C' ,

(
  ['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Net Revenue [$MM]'] *1000
    \
['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Sales Volume [kt]']
)
    
   ,CONTINUE) ;

# --------------------------------------------------------------------------------------------
# Name Define versões calculadas
# Desc A partir dessa regra só calcula para versões dinâmicas
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
[]=IF(ELISANC( 'ALL.D.Version', 'Dynamic Versions', !ALL.D.Version ) <> 0
  ,CONTINUE
  ,STET
  ); 

[]=IF(ELISANC( 'ALL.D.Version', 'Dynamic Versions', !ALL.D.Version ) <> 0 
  &
  DB( 'ALL.001.Actual_Control', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Flag' )@='ACTUAL',
        ['ALL.D.Version':'ALL.D.Version':'RE'],
        CONTINUE) ;


# --------------------------------------------------------------------------------------------
#
#                      			INICIO DO BLOCO CALCULOS CONVERSÃO MOEDA
#
# --------------------------------------------------------------------------------------------
# --------------------------------------------------------------------------------------------
# Name: Conversão de Moedas para mertica ajuste
# Desc: Conversão de moedas para os padrões USD, BRL e EUR
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------

###############################################################
#-------------------------------------# USD CONV #-----------------------------------------
###############################################################

  ['ALL.D.Currency':'ALL.D.Currency':'USD Conv.' , 'REV.M.100.Revenue_Consolidated':{'REV.M.100.Revenue_Consolidated':'Net Revenue [$MM]','REV.M.100.Revenue_Consolidated':'Gross Revenue [$MM]'}] = N:

  #USD  
  ['ALL.D.Currency':'ALL.D.Currency':'USD']
     +
  # BRL PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'BRL'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )

+         
  #   EUR PARA USD  
 ['ALL.D.Currency':'ALL.D.Currency':'EUR'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
                                              
      +
  # ARS PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'ARS'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX ARS$/US$', 'Value' )  
      +
  # BOB  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'BOB'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX BOB$/US$', 'Value' )  
      +
  # CAD  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'CAD'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX CAD$/US$', 'Value' )  

          +
  # TRY  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'TRY'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX TRY$/US$', 'Value' )  

     +
 # UYU PARA USD  
  ['ALL.D.Currency':'ALL.D.Currency':'UYU'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX UYU$/US$', 'Value' )  
    ;

###############################################################
#-------------------------------------# BRL CONV #-----------------------------------------
###############################################################

  ['ALL.D.Currency':'ALL.D.Currency':'BRL Conv.' ,  'REV.M.100.Revenue_Consolidated':{'REV.M.100.Revenue_Consolidated':'Net Revenue [$MM]','REV.M.100.Revenue_Consolidated':'Gross Revenue [$MM]'}] = N:
  #    #BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'BRL']
     +
  #  USD PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'USD'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )

+         
  #   EUR PARA BRL  
 ['ALL.D.Currency':'ALL.D.Currency':'EUR'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
                                              *DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )

    
    +
  #  ARS PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'ARS'] * 
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX ARS$/US$', 'Value' ) )
    +
  #  BOB PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'BOB'] * 
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX BOB$/US$', 'Value' ) )
        +
  #  CAD PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'CAD'] *
      (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX CAD$/US$', 'Value' ) )

            +
  #  TRY PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'TRY'] *
      (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX TRY$/US$', 'Value' ) )

      +
    # UYU PARA BRL
  ['ALL.D.Currency':'ALL.D.Currency':'UYU'] * 
    
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX UYU$/US$', 'Value' ) )
    ;






###############################################################
#-------------------------------------# EUR CONV #-----------------------------------------
###############################################################

  ['ALL.D.Currency':'ALL.D.Currency':'EUR Conv.' , 'REV.M.100.Revenue_Consolidated':{'REV.M.100.Revenue_Consolidated':'Net Revenue [$MM]','REV.M.100.Revenue_Consolidated':'Gross Revenue [$MM]'}] = N:
  #EUR     
  ['ALL.D.Currency':'ALL.D.Currency':'EUR']
     +
   # USD PARA EUR  
  ['ALL.D.Currency':'ALL.D.Currency':'USD'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
       +
    # BRL PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'BRL']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
 )

       +
    # ARS PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'ARS']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX ARS$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
 )

           +
    # BOB PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'BOB']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX BOB$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
 )

               +
    # CAD PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'CAD']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX CAD$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
 )
               +
    # TRY PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'TRY']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX TRY$/US$', 'Value' ) )
 \DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
 )

                   +
    # UYU PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'UYU']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX UYU$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
 )
    
    ;

# --------------------------------------------------------------------------------------------
# Name: Regra Totalizador Volume e Preco no Total Produto
# Desc: 
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':{'Price Premium [$/ton]' , 'Reference Price [$/ton]' , 'Sales Volume [kt]'} , 'ALL.D.Products':'ALL.D.Products':'Total Products']=C:
  0;

# --------------------------------------------------------------------------------------------
# Name: % Operational Tax'
# Desc: % Operational Tax'
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'% Operational Tax' ] = N:
  DB( 'STG.100.DataBase_Uploads',
      !ALL.D.Year,
      !ALL.D.Month,
      !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     !ALL.D.Products,
     '% Operational Tax',
     'ALL.D.Account_Line':'Total Accounts Line',
     'STG.M.100.DataBaseUploads':'Value' 
     );

C:
(
    ['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Gross Revenue [$MM]']
  -
  ['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Net Revenue [$MM]'] 
  )

\
  ['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Net Revenue [$MM]'] 

  ;
    
# --------------------------------------------------------------------------------------------
# Name: Reference Price [$/ton]
# Desc: Reference Price [$/ton]
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Reference Price [$/ton]' , 'ALL.D.Market':'ALL.D.Market':'Domestic'] = N:
  DB( 'STG.100.DataBase_Uploads',
      !ALL.D.Year,
      !ALL.D.Month,
      !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     !ALL.D.Products,
     'Reference Price [$/ton]',
     'ALL.D.Account_Line':'Total Accounts Line',
     'STG.M.100.DataBaseUploads':'Value' 
     );


# --------------------------------------------------------------------------------------------
# Name:'Sales Volume [kt]
# Desc: 'Sales Volume [kt]
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Sales Volume [kt]' , 'ALL.D.Market':'ALL.D.Market':'Domestic'] = N:
  DB( 'STG.100.DataBase_Uploads',
      !ALL.D.Year,
      !ALL.D.Month,
      !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     !ALL.D.Products,
     'Local Market Sales Volume [kt]',
     'ALL.D.Account_Line':'Total Accounts Line',
     'STG.M.100.DataBaseUploads':'Value' 
     );


  ['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Sales Volume [kt]' , 'ALL.D.Market':'ALL.D.Market':'Export'] = N:
  DB( 'STG.100.DataBase_Uploads',
      !ALL.D.Year,
      !ALL.D.Month,
      !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     !ALL.D.Products,
     'Export Market Sales Volume [kt]',
     'ALL.D.Account_Line':'Total Accounts Line',
     'STG.M.100.DataBaseUploads':'Value' 
     );

# --------------------------------------------------------------------------------------------
# Name:Third Part Sales Volume [kt]
# Desc: Third Part Sales Volume [kt]
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['REV.M.100.Revenue_Consolidated':'REV.M.100.Revenue_Consolidated':'Third Part Sales Volume [kt]' , 'ALL.D.Market':'ALL.D.Market':'Domestic'] = N:
