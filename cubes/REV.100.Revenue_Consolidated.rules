,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }] 
  =>DB('DFS.200.KPIs', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'Revenue' ,'Value');

