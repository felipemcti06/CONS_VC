  FEEDERS;
# =============
# =============
# # --------------------------------------------------------------------------------------------
# # Name: Feedes Forecast 
# # Desc: Feedes Forecast 
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
 ['ALL.D.Version':'ALL.D.Version':'RE'] => ['ALL.D.Version':'ALL.D.Version':'Dynamic Versions'];


# --------------------------------------------------------------------------------------------
# Name: Conversão de Moedas
# Desc: Conversão de moedas para os padrões USD, BRL e EUR
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
[ 'DFS.M.120.Financial_Results':'DFS.M.120.Financial_Results':'Adjustments','ALL.D.Currency':'ALL.D.Currency':'Total Currency','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>
DB( 'DFS.120.Financial_Results', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'BRL Conv.', !ALL.D.Region, !DFS.D.Accounts_Fin_Results, 'Adjustments' ),
DB( 'DFS.120.Financial_Results', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'EUR Conv.', !ALL.D.Region, !DFS.D.Accounts_Fin_Results, 'Adjustments' ),
DB( 'DFS.120.Financial_Results', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'USD Conv.', !ALL.D.Region, !DFS.D.Accounts_Fin_Results, 'Adjustments' )

    
    ;

    
# --------------------------------------------------------------------------------------------
#                      			BLOCO DE FEEDERS EXTERNOS
# --------------------------------------------------------------------------------------------

###############################################################
#-------------------------------------# DFS.100#-----------------------------------------
###############################################################

# --------------------------------------------------------------------------------------------
# Name:Accrual of Interest (LC)
# Desc: Accrual of Interest (LC)
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 
[ 'DFS.D.Accounts_Fin_Results':'DFS.D.Accounts_Fin_Results':'Accrual of Interest (LC)'
 ,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'DFS.100.Profit_and_Loss', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, 'PROD099', 'Interest Accrual', !DFS.M.120.Financial_Results );
# --------------------------------------------------------------------------------------------
# Name:Financial Expenses
# Desc: Financial Expenses
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 
[ 'DFS.D.Accounts_Fin_Results':'DFS.D.Accounts_Fin_Results':'Financial Expenses'
 ,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'DFS.100.Profit_and_Loss', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, 'PROD099', 'Financial Expenses', !DFS.M.120.Financial_Results );

# --------------------------------------------------------------------------------------------
# Name:Total Financial Revenues
# Desc: Total Financial Revenues
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 
[ 'DFS.D.Accounts_Fin_Results':'DFS.D.Accounts_Fin_Results':'Total Financial Revenues'
 ,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'DFS.100.Profit_and_Loss', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, 'PROD099', 'Financial Revenues', !DFS.M.120.Financial_Results);



# --------------------------------------------------------------------------------------------
# Name: Total Foreign Exchange Variation
# Desc:  Total Foreign Exchange Variation
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 
[ 'DFS.D.Accounts_Fin_Results':'DFS.D.Accounts_Fin_Results':'Total Foreign Exchange Variation'
 ,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'DFS.100.Profit_and_Loss', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, 'PROD099', 'FX Variation', !DFS.M.120.Financial_Results );


# --------------------------------------------------------------------------------------------
# Name: Total Hedge Results
# Desc:  Total Hedge Results
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 
[ 'DFS.D.Accounts_Fin_Results':'DFS.D.Accounts_Fin_Results':'Total Hedge Results'
 ,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'DFS.100.Profit_and_Loss', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, 'PROD099', 'Others', !DFS.M.120.Financial_Results );

# --------------------------------------------------------------------------------------------
# Name: Total Other Financial Revenues
# Desc:  Total Other Financial Revenues
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 
[ 'DFS.D.Accounts_Fin_Results':'DFS.D.Accounts_Fin_Results':'Total Other Financial Revenues'
 ,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'DFS.100.Profit_and_Loss', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, 'PROD099', 'Others', !DFS.M.120.Financial_Results );


###############################################################
#-------------------------------------# DFS.140#-----------------------------------------
###############################################################

# --------------------------------------------------------------------------------------------
# Name: Financial Expenses - Cash
# Desc:   Financial Expenses - Cash
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 
[ 'DFS.D.Accounts_Fin_Results':'DFS.D.Accounts_Fin_Results':'Financial Expenses - Cash'
 ,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'DFS.140.Indirect_Cash_Flow', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, 'Other Financial Expenses', !DFS.M.120.Financial_Results );



# --------------------------------------------------------------------------------------------
# Name: Liquidation
# Desc:   Liquidation
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 
[ 'DFS.D.Accounts_Fin_Results':'DFS.D.Accounts_Fin_Results':'Liquidation'
 ,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'DFS.140.Indirect_Cash_Flow', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, 'Derivatives settlement', !DFS.M.120.Financial_Results );
