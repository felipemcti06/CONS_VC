# --------------------------------------------------------------------------------------------
#Name Qty Months
#Desc Make the calculation the number of months copied
#Date 02/02/2024
# --------------------------------------------------------------------------------------------
['Qty Months'] =S: 
STR( IF(  DB( 'SYS.900.Version_Copy_Parameter', !SYS.D.Value,'Start Period' ) @= ''
   % DB( 'SYS.900.Version_Copy_Parameter', !SYS.D.Value, 'End Period' ) @= ''
	, 0
    , CONTINUE
)
, 2, 0 );


['Qty Months'] =S: 
STR( DIMIX( 'SYS.D.Version_Copy_Year_Month', DB( 'SYS.900.Version_Copy_Parameter', !SYS.D.Value, 'End Period' ))
   - DIMIX( 'SYS.D.Version_Copy_Year_Month', DB( 'SYS.900.Version_Copy_Parameter', !SYS.D.Value, 'Start Period' )) + 1
, 2, 0 );