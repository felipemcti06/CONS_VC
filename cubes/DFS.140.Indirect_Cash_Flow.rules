  FEEDERS;
# =============
# # --------------------------------------------------------------------------------------------
# # Name: Feedes Forecast 
# # Desc: Feedes Forecast 
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
 ['ALL.D.Version':'ALL.D.Version':'RE'] => ['ALL.D.Version':'ALL.D.Version':'Dynamic Versions'];

    
# # --------------------------------------------------------------------------------------------
# # Name: Adj EBITDA LTM
# # Desc: Adj EBITDA LTM
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'EBITDA'] => ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Adj EBITDA LTM'];
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Dividends received'] => ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Adj EBITDA LTM'];

# # --------------------------------------------------------------------------------------------
# # Name: Leverage
# # Desc: Leverage
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
    
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'EBITDA'] => ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Leverage'];
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Dividends received'] => ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Leverage'];    
# --------------------------------------------------------------------------------------------
# Name: ConversÃ£o de Moedas
# Desc: ConversÃ£o de moedas para os padrÃµes USD, BRL e EUR
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.M.140.Indirect_Cash_Flow':'DFS.M.140.Indirect_Cash_Flow':'Adjustments', 'ALL.D.Currency':'ALL.D.Currency':'Total Currency','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'DFS.140.Indirect_Cash_Flow', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'BRL Conv.', !ALL.D.Region, !DFS.D.Accounts_ICF, 'Adjustments' ),
    DB( 'DFS.140.Indirect_Cash_Flow', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'EUR Conv.', !ALL.D.Region, !DFS.D.Accounts_ICF, 'Adjustments' ),
    DB( 'DFS.140.Indirect_Cash_Flow', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'USD Conv.', !ALL.D.Region, !DFS.D.Accounts_ICF, 'Adjustments' )
    
    ;

