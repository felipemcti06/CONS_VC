# # Desc: Income Tax on Financial Investments
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Tax on Financial Revenue','DFS.M.140.Indirect_Cash_Flow':'DFS.M.140.Indirect_Cash_Flow':'Value'] = N:
(DB( 'DFS.140.Indirect_Cash_Flow', 
    !ALL.D.Year,
    !ALL.D.Month,
    !ALL.D.Version, 
    !ALL.D.Currency,
    !ALL.D.Region,
    'Financial Revenue', 
    'DFS.M.140.Indirect_Cash_Flow':'Total Value' )
    +
    DB('STG.100.DataBase_Uploads', 
     !ALL.D.Year, 
     !ALL.D.Month,
     !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     'ALL.D.Products':'Total Products',
     'Additions/Low in Cash Investments',
      'ALL.D.Account_Line':'Total Accounts Line', 
     'Value'
       )

 )
    
    *
    -DB( 'ALL.015.Region_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Region, '% Rate Over Financial Investments', 'Value' );


