# # Desc:  Amortization
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Amortization'] = N:
-DB( 'DFS.180.Gross_Debt',
    !ALL.D.Year, 
    !ALL.D.Month,
    !ALL.D.Version,
    !ALL.D.Currency,
    !ALL.D.Region,
    'DFS.D.Accounts_Debt':'Principal Amortization Total',
    !DFS.M.140.Indirect_Cash_Flow
  );

# # --------------------------------------------------------------------------------------------
# # Name: Funding
# # Desc: Funding
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Funding'] = N:
-DB( 'DFS.180.Gross_Debt',
    !ALL.D.Year, 
    !ALL.D.Month,
    !ALL.D.Version,
    !ALL.D.Currency,
    !ALL.D.Region,
    'DFS.D.Accounts_Debt':'Funding Total',
    !DFS.M.140.Indirect_Cash_Flow
  );

# # --------------------------------------------------------------------------------------------
# # Name: SCF before dividends
# # Desc: SCF before dividends
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'SCF before dividends'] = N:
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'EBITDA' ]
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Income tax on transactions']
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Working capital' ]
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Non expansion capex']
     +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Dividends received']
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Financial Results']
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'OOR.010.001' ]
             
    ;
# # --------------------------------------------------------------------------------------------
# # Name: Sustainable Cash Flow
# # Desc: Sustainable Cash Flow
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Sustainable Cash Flow'] = N:
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'SCF before dividends']
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Payment of dividends to Controlling' ]
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Payment of dividends to Minority']
    ;

# # --------------------------------------------------------------------------------------------
# # Name: Cash generation before financing
# # Desc:Cash generation before financing
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Cash generation before financing'] = N:
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Sustainable Cash Flow' ]
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Expansion capex']
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Inv/Div in Subsidiaries and Affiliates' ]   
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'FX/Others' ]      
    ;
# # --------------------------------------------------------------------------------------------
# # Name: Cash generation before financing
# # Desc:Cash generation before financing
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Change in cash'] = 
    
 ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Cash generation before financing' ]   
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Intercompany dividends' ]
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Amortization' ]
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Funding' ]
    
     
    ;


# # --------------------------------------------------------------------------------------------
# # Name: Final Cash Position
# # Desc:Final Cash Position
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Final Cash Position','DFS.M.140.Indirect_Cash_Flow':'DFS.M.140.Indirect_Cash_Flow':'Value'] = N:
    
 ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Initial Cash Balance' ]    
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Change in cash']

    
     
    ;


