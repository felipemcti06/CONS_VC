# =============
  SKIPCHECK;
  FEEDSTRINGS;
# =============

# --------------------------------------------------------------------------------------------
#
#                      			INICIO DO BLOCO CALCULOS 
#
# --------------------------------------------------------------------------------------------


# # --------------------------------------------------------------------------------------------
# # Name: INITIAL CASH BALANCE
# # Desc: INITIAL CASH BALANCE
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Initial Cash Balance'] = 
    IF( DTYPE( 'ALL.D.Month', !ALL.D.Month )@='C', 

    DB( 'DFS.140.Indirect_Cash_Flow',
        !ALL.D.Year,
        DB('}ElementAttributes_ALL.D.Month', !ALL.D.Month, 'Aux Totalizadores Inicial'),
        !ALL.D.Version,
        !ALL.D.Currency,
        !ALL.D.Region,
        !DFS.D.Accounts_ICF,
        !DFS.M.140.Indirect_Cash_Flow )

    , CONTINUE );


# # --------------------------------------------------------------------------------------------
# # Name: Final Cash Position
# # Desc:Final Cash Position
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Final Cash Position'] = 
    
    IF( DTYPE( 'ALL.D.Month', !ALL.D.Month )@='C', 

    DB( 'DFS.140.Indirect_Cash_Flow',
        !ALL.D.Year,
        DB('}ElementAttributes_ALL.D.Month', !ALL.D.Month, 'Aux Totalizadores'),
        !ALL.D.Version,
        !ALL.D.Currency,
        !ALL.D.Region,
        !DFS.D.Accounts_ICF,
        !DFS.M.140.Indirect_Cash_Flow )

    , CONTINUE );
# # --------------------------------------------------------------------------------------------
# # Name: MTM
# # Desc: MTM
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'MTM'] = 
    
    IF( DTYPE( 'ALL.D.Month', !ALL.D.Month )@='C', 

    DB( 'DFS.140.Indirect_Cash_Flow',
        !ALL.D.Year,
        DB('}ElementAttributes_ALL.D.Month', !ALL.D.Month, 'Aux Totalizadores'),
        !ALL.D.Version,
        !ALL.D.Currency,
        !ALL.D.Region,
        !DFS.D.Accounts_ICF,
        !DFS.M.140.Indirect_Cash_Flow )

    , CONTINUE );

# --------------------------------------------------------------------------------------------
# Name Define versÃµes calculadas
# Desc A partir dessa regra sÃ³ calcula para versÃµes dinÃ¢micas
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
[]=IF(ELISANC( 'ALL.D.Version', 'Dynamic Versions', !ALL.D.Version ) <> 0
  % !ALL.D.Version@='RE' 
  ,CONTINUE
  ,STET
  ); 

[]=IF(ELISANC( 'ALL.D.Version', 'Dynamic Versions', !ALL.D.Version ) <> 0 
  &
  DB( 'ALL.001.Actual_Control', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Flag' )@='ACTUAL',
        ['ALL.D.Version':'ALL.D.Version':'RE'],
        CONTINUE) ;


# --------------------------------------------------------------------------------------------
#
#                      			INICIO DO BLOCO CALCULOS CONVERSÃƒO MOEDA
#
# --------------------------------------------------------------------------------------------
# --------------------------------------------------------------------------------------------
# Name: ConversÃ£o de Moedas para mertica ajuste
# Desc: ConversÃ£o de moedas para os padrÃµes USD, BRL e EUR
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------

###############################################################
#-------------------------------------# USD CONV #-----------------------------------------
###############################################################

  ['ALL.D.Currency':'ALL.D.Currency':'USD Conv.' , 'DFS.M.140.Indirect_Cash_Flow':'DFS.M.140.Indirect_Cash_Flow':'Adjustments'] = N:

  #USD  
  ['ALL.D.Currency':'ALL.D.Currency':'USD']
     +
  # BRL PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'BRL'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )

+         
  #   EUR PARA USD  
 ['ALL.D.Currency':'ALL.D.Currency':'EUR'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
                                              
      +
  # ARS PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'ARS'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX ARS$/US$', 'Value' )  
      +
  # BOB  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'BOB'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX BOB$/US$', 'Value' )  
      +
  # CAD  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'CAD'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX CAD$/US$', 'Value' )  

          +
  # TRY  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'TRY'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX TRY$/US$', 'Value' )  

     +
 # UYU PARA USD  
  ['ALL.D.Currency':'ALL.D.Currency':'UYU'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX UYU$/US$', 'Value' )  
    ;

###############################################################
#-------------------------------------# BRL CONV #-----------------------------------------
###############################################################

  ['ALL.D.Currency':'ALL.D.Currency':'BRL Conv.' , 'DFS.M.140.Indirect_Cash_Flow':'DFS.M.140.Indirect_Cash_Flow':'Adjustments'] = N:
  #    #BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'BRL']
     +
  #  USD PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'USD'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )

+         
  #   EUR PARA BRL  
 ['ALL.D.Currency':'ALL.D.Currency':'EUR'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
                                              *DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )

    
    +
  #  ARS PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'ARS'] * 
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX ARS$/US$', 'Value' ) )
    +
  #  BOB PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'BOB'] * 
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX BOB$/US$', 'Value' ) )
        +
  #  CAD PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'CAD'] *
      (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX CAD$/US$', 'Value' ) )

            +
  #  TRY PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'TRY'] *
      (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX TRY$/US$', 'Value' ) )

      +
    # UYU PARA BRL
  ['ALL.D.Currency':'ALL.D.Currency':'UYU'] * 
    
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX UYU$/US$', 'Value' ) )
    ;






###############################################################
#-------------------------------------# EUR CONV #-----------------------------------------
###############################################################

  ['ALL.D.Currency':'ALL.D.Currency':'EUR Conv.' , 'DFS.M.140.Indirect_Cash_Flow':'DFS.M.140.Indirect_Cash_Flow':'Adjustments'] = N:
  #EUR     
  ['ALL.D.Currency':'ALL.D.Currency':'EUR']
     +
   # USD PARA EUR  
  ['ALL.D.Currency':'ALL.D.Currency':'USD'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
       +
    # BRL PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'BRL']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX R$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
 )

       +
    # ARS PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'ARS']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX ARS$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
 )

           +
    # BOB PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'BOB']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX BOB$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
 )

               +
    # CAD PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'CAD']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX CAD$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
 )
               +
    # TRY PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'TRY']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX TRY$/US$', 'Value' ) )
 \DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
 )

                   +
    # UYU PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'UYU']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX UYU$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
 )
    
    ;

# --------------------------------------------------------------------------------------------
#
#                      			INICIO DO BLOCO CALCULOS CONVERSÃƒO MOEDA  SALDO FINAL
#
# --------------------------------------------------------------------------------------------
###############################################################
#-------------------------------------# BRL CONV #-----------------------------------------
###############################################################

# # --------------------------------------------------------------------------------------------
# # Name: Final Cash Position Moedas CONV.
# # Desc:Final Cash Position Moedas CONV.
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Final Cash Position Aux' , 'ALL.D.Currency':'ALL.D.Currency':'BRL Conv.'] = N:
    
  #    #BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'BRL']
     +
  #  USD PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'USD'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )

+         
  #   EUR PARA BRL  
 ['ALL.D.Currency':'ALL.D.Currency':'EUR'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
                                              *DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )

    
    +
  #  ARS PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'ARS'] * 
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX ARS$/US$', 'Value' ) )
    +
  #  BOB PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'BOB'] * 
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX BOB$/US$', 'Value' ) )
        +
  #  CAD PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'CAD'] *
      (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX CAD$/US$', 'Value' ) )

            +
  #  TRY PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'TRY'] *
      (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX TRY$/US$', 'Value' ) )

      +
    # UYU PARA BRL
  ['ALL.D.Currency':'ALL.D.Currency':'UYU'] * 
    
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX UYU$/US$', 'Value' ) )
    ;
###############################################################
#-------------------------------------# USD CONV #-----------------------------------------
###############################################################

# # --------------------------------------------------------------------------------------------
# # Name: Final Cash Position Moedas CONV.
# # Desc:Final Cash Position Moedas CONV.
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------

  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Final Cash Position Aux' , 'ALL.D.Currency':'ALL.D.Currency':'USD Conv.'] = N:
    
 #USD  
  ['ALL.D.Currency':'ALL.D.Currency':'USD']
     +
  # BRL PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'BRL'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )

+         
  #   EUR PARA USD  
 ['ALL.D.Currency':'ALL.D.Currency':'EUR'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
                                              
      +
  # ARS PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'ARS'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX ARS$/US$', 'Value' )  
      +
  # BOB  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'BOB'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX BOB$/US$', 'Value' )  
      +
  # CAD  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'CAD'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX CAD$/US$', 'Value' )  

          +
  # TRY  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'TRY'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX TRY$/US$', 'Value' )  

     +
 # UYU PARA USD  
  ['ALL.D.Currency':'ALL.D.Currency':'UYU'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX UYU$/US$', 'Value' )  
    ;

###############################################################
#-------------------------------------# EUR CONV #-----------------------------------------
###############################################################
# # --------------------------------------------------------------------------------------------
# # Name: Final Cash Position Moedas CONV.
# # Desc:Final Cash Position Moedas CONV.
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------

  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Final Cash Position Aux' , 'ALL.D.Currency':'ALL.D.Currency':'EUR Conv.'] = N:
#EUR     
  ['ALL.D.Currency':'ALL.D.Currency':'EUR']
     +
   # USD PARA EUR  
  ['ALL.D.Currency':'ALL.D.Currency':'USD'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )
       +
    # BRL PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'BRL']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
 )

       +
    # ARS PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'ARS']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX ARS$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
 )

           +
    # BOB PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'BOB']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX BOB$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
 )

               +
    # CAD PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'CAD']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX CAD$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
 )
               +
    # TRY PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'TRY']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX TRY$/US$', 'Value' ) )
 \DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
 )

                   +
    # UYU PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'UYU']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX UYU$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
 )
    
    ;


# # --------------------------------------------------------------------------------------------
# # Name: INITIAL CASH BALANCE
# # Desc: INITIAL CASH BALANCE
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Initial Cash Balance','DFS.M.140.Indirect_Cash_Flow':'DFS.M.140.Indirect_Cash_Flow':'Value'] = N:
  DB('STG.100.DataBase_Uploads', 
     !ALL.D.Year, 
     !ALL.D.Month,
     !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     'ALL.D.Products':'Total Products',
     'INITIAL CASH BALANCE',
      'ALL.D.Account_Line':'Total Accounts Line', 
     'Value'
)
    +

DB( 'DFS.140.Indirect_Cash_Flow', 
    DB( 'SYS.200.Time_Travel', !ALL.D.Year, !ALL.D.Month, '-1', 'Ano' ),
    DB( 'SYS.200.Time_Travel', !ALL.D.Year, !ALL.D.Month, '-1', 'Mes' ),
    !ALL.D.Version,
    !ALL.D.Currency,
    !ALL.D.Region,
    'Final Cash Position',
    !DFS.M.140.Indirect_Cash_Flow 
  )    
;

