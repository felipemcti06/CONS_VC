    !ALL.D.Month,
    !ALL.D.Version,
    !ALL.D.Currency,
    !ALL.D.Region,
    'DFS.D.Accounts_Debt':'Interest Amortization Total',
    !DFS.M.140.Indirect_Cash_Flow 
  );


# # --------------------------------------------------------------------------------------------
# # Name: Financial Revenues
# # Desc: Financial Revenues
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Financial Revenue','DFS.M.140.Indirect_Cash_Flow':'DFS.M.140.Indirect_Cash_Flow':'Value'] = N:

    ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Initial Cash Balance']
    *
    DB( 'ALL.015.Region_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Region, '% Caixa Invested', 'Value' )

    *
    DB( 'ALL.015.Region_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Region, '% Cash Investment Return', 'Value' )
    +
    DB('STG.100.DataBase_Uploads', 
     !ALL.D.Year, 
     !ALL.D.Month,
     !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     'ALL.D.Products':'Total Products',
     'Other Financial income',
      'ALL.D.Account_Line':'Total Accounts Line', 
     'Value'
       );
# # --------------------------------------------------------------------------------------------
# # Name: Invested Cash
# # Desc: Invested Cash
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Invested Cash','DFS.M.140.Indirect_Cash_Flow':'DFS.M.140.Indirect_Cash_Flow':'Value'] = N:

    ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Initial Cash Balance']
    *
    DB( 'ALL.015.Region_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Region, '% Caixa Invested', 'Value' )


    
    ;
 C:
    IF( DTYPE( 'ALL.D.Month', !ALL.D.Month )@='C', 

    DB( 'DFS.140.Indirect_Cash_Flow',
        !ALL.D.Year,
        DB('}ElementAttributes_ALL.D.Month', !ALL.D.Month, 'Aux Totalizadores'),
        !ALL.D.Version,
        !ALL.D.Currency,
        !ALL.D.Region,
        !DFS.D.Accounts_ICF,
        !DFS.M.140.Indirect_Cash_Flow )

    , CONTINUE );
