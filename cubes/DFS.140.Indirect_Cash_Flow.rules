# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.M.140.Indirect_Cash_Flow':'DFS.M.140.Indirect_Cash_Flow':'Total Value','DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Sustainable Cash Flow' , 'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }]
  => DB( 'DFS.200.KPIs', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, 'ALL.D.Products':'PROD099', 'Sust. Cash Flow in Hard Currency' ,'Value');

