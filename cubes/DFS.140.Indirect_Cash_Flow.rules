# --------------------------------------------------------------------------------------------
# Name: EBITDA
# Desc: EBITDA
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'EBITDA'] = N:
   DB( 'DFS.100.Profit_and_Loss',
       !ALL.D.Year,
       !ALL.D.Month,
       !ALL.D.Version,
       !ALL.D.Currency,
       !ALL.D.Region,
       'ALL.D.Products':'Total Products',
       'EBITDA',
       !DFS.M.140.Indirect_Cash_Flow
     );

# # --------------------------------------------------------------------------------------------
# # Name: Income tax on transactions
# # Desc: Income tax on transactions
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Income tax on transactions','DFS.M.140.Indirect_Cash_Flow':'DFS.M.140.Indirect_Cash_Flow':'Value'] = N:
  DB('STG.100.DataBase_Uploads', 
     !ALL.D.Year, 
     !ALL.D.Month,
     !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     'ALL.D.Products':'Total Products',
     'Income Tax Payments - Cash',
      'ALL.D.Account_Line':'Total Accounts Line', 
     'Value'
);
# # --------------------------------------------------------------------------------------------
# # Name: Working capital
# # Desc: Working capital
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Working capital'] = N:
DB( 'DFS.160.Working_Capital',
    !ALL.D.Year,
    !ALL.D.Month,
    !ALL.D.Version,
    !ALL.D.Currency,
    !ALL.D.Region,
    '(Invest.)/Divest. Working Capital',
    !DFS.M.140.Indirect_Cash_Flow
  );
