# # --------------------------------------------------------------------------------------------
# # Name: Final Net Debt
# # Desc:  Final Net Debt
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Final Net Debt'] = N:
    
 ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Final Cash Position' ]    
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Final Debt Position' ]
    +
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'MTM']
    
     
    ;

C:
    IF( DTYPE( 'ALL.D.Month', !ALL.D.Month )@='C', 

    DB( 'DFS.140.Indirect_Cash_Flow',
        !ALL.D.Year,
        DB('}ElementAttributes_ALL.D.Month', !ALL.D.Month, 'Aux Totalizadores'),
        !ALL.D.Version,
        !ALL.D.Currency,
        !ALL.D.Region,
        !DFS.D.Accounts_ICF,
        !DFS.M.140.Indirect_Cash_Flow )

    , CONTINUE );

# # --------------------------------------------------------------------------------------------
# # Name: FX on Cash Position
# # Desc: FX on Cash Position
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
   ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'FX on Cash Position' , 'ALL.D.Currency':'ALL.D.Currency': {'BRL Conv.','EUR Conv.','USD Conv.'}]=N:

   ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Final Cash Position Aux' ]    
     
          -
    (
    ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Sustainable Cash Flow']+
    ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Expansion capex']+
    ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Inv/Div in Subsidiaries and Affiliates']+
    ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Intercompany dividends']+
    ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Amortization']+
    ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Funding']+


    ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Initial Cash Balance']  

      
    ) 
    -
    ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Others' ]
  

      
 ;
    
# # --------------------------------------------------------------------------------------------
# # Name: Adj EBITDA LTM
# # Desc: Adj EBITDA LTM
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
 ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Adj EBITDA LTM' ]=N:
# # EBITDA
   (
    DB( 'DFS.140.Indirect_Cash_Flow',
    DB('SYS.200.Time_Travel',!ALL.D.Year,!ALL.D.Month,'-12','Ano'), 
    'ALL.D.Month':'YTD 12', 
    !ALL.D.Version,
    !ALL.D.Currency,
    !ALL.D.Region,
    'EBITDA',
    !DFS.M.140.Indirect_Cash_Flow )
- 
   DB( 'DFS.140.Indirect_Cash_Flow',
    DB('SYS.200.Time_Travel',!ALL.D.Year,!ALL.D.Month,'-12','Ano'), 
    'YTD ' | !ALL.D.Month, 
    !ALL.D.Version,
    !ALL.D.Currency,
    !ALL.D.Region,
    'EBITDA',
    !DFS.M.140.Indirect_Cash_Flow )
+
    DB( 'DFS.140.Indirect_Cash_Flow',
    !ALL.D.Year,
    'YTD ' | !ALL.D.Month, 
    !ALL.D.Version,
    !ALL.D.Currency,
    !ALL.D.Region,
    'EBITDA',
    !DFS.M.140.Indirect_Cash_Flow )
   
   )

+
# # Dividends received

   (
    DB( 'DFS.140.Indirect_Cash_Flow',
    DB('SYS.200.Time_Travel',!ALL.D.Year,!ALL.D.Month,'-12','Ano'), 
    'ALL.D.Month':'YTD 12', 
    !ALL.D.Version,
    !ALL.D.Currency,
    !ALL.D.Region,
    'Dividends received',
    !DFS.M.140.Indirect_Cash_Flow )
- 
   DB( 'DFS.140.Indirect_Cash_Flow',
    DB('SYS.200.Time_Travel',!ALL.D.Year,!ALL.D.Month,'-12','Ano'), 
    'YTD ' | !ALL.D.Month, 
    !ALL.D.Version,
    !ALL.D.Currency,
    !ALL.D.Region,
    'Dividends received',
    !DFS.M.140.Indirect_Cash_Flow )
+
    DB( 'DFS.140.Indirect_Cash_Flow',
    !ALL.D.Year,
    'YTD ' | !ALL.D.Month, 
    !ALL.D.Version,
    !ALL.D.Currency,
    !ALL.D.Region,
    'Dividends received',
    !DFS.M.140.Indirect_Cash_Flow )
   
   )
   +
   [ 'DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Adjusts LTM'];
   
   C:
    IF( DTYPE( 'ALL.D.Month', !ALL.D.Month )@='C', 

    DB( 'DFS.140.Indirect_Cash_Flow',
        !ALL.D.Year,
        DB('}ElementAttributes_ALL.D.Month', !ALL.D.Month, 'Aux Totalizadores'),
        !ALL.D.Version,
        !ALL.D.Currency,
        !ALL.D.Region,
        !DFS.D.Accounts_ICF,
        !DFS.M.140.Indirect_Cash_Flow )

    , CONTINUE );
   
# # --------------------------------------------------------------------------------------------
# # Name: Leverage
# # Desc: Leverage
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
 ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Leverage' ]=
   [ 'DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Final Net Debt']
   \
   ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Adj EBITDA LTM'];

# C:
#     IF( DTYPE( 'ALL.D.Month', !ALL.D.Month )@='C', 

#     DB( 'DFS.140.Indirect_Cash_Flow',
#         !ALL.D.Year,
#         DB('}ElementAttributes_ALL.D.Month', !ALL.D.Month, 'Aux Totalizadores'),
#         !ALL.D.Version,
#         !ALL.D.Currency,
#         !ALL.D.Region,
#         !DFS.D.Accounts_ICF,
#         !DFS.M.140.Indirect_Cash_Flow )

#     , CONTINUE );
 # # --------------------------------------------------------------------------------------------
# # Name: FCL EconÃ´mico
# # Desc: FCL EconÃ´mico
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
 ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'FCL EconÃ´mico' ]=N:
   [ 'DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Cash generation before financing']
   *
  DB( 'ALL.015.Region_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Region, '% Participation', 'Value' )
;

 # # --------------------------------------------------------------------------------------------
# # Name: FCL EconÃ´mico
# # Desc: FCL EconÃ´mico
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
 ['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'DL EconÃ´mica' ]=N:
   [ 'DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Final Net Debt']
   *
  DB( 'ALL.015.Region_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Region, '% Participation', 'Value' )
;

C:
    IF( DTYPE( 'ALL.D.Month', !ALL.D.Month )@='C', 

    DB( 'DFS.140.Indirect_Cash_Flow',
        !ALL.D.Year,
        DB('}ElementAttributes_ALL.D.Month', !ALL.D.Month, 'Aux Totalizadores'),
        !ALL.D.Version,
        !ALL.D.Currency,
        !ALL.D.Region,
        !DFS.D.Accounts_ICF,
        !DFS.M.140.Indirect_Cash_Flow )

    , CONTINUE );
