['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'Final Cash Position','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' } , 'ALL.D.Currency':'ALL.D.Currency':'Total Currency'
]=>['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'FX on Cash Position' , 'ALL.D.Currency':'ALL.D.Currency':'BRL Conv.'],
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'FX on Cash Position' , 'ALL.D.Currency':'ALL.D.Currency':'EUR Conv.'],
['DFS.D.Accounts_ICF':'DFS.D.Accounts_ICF':'FX on Cash Position' , 'ALL.D.Currency':'ALL.D.Currency':'USD Conv.'];
    
 

    
    
