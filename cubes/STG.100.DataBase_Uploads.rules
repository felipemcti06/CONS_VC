# =============
  FEEDERS;
# =============
# # --------------------------------------------------------------------------------------------
# # Name: Feedes Forecast 
# # Desc: Feedes Forecast 
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
 ['ALL.D.Version':'ALL.D.Version':'RE'] => ['ALL.D.Version':'ALL.D.Version':'Dynamic Versions'];

# --------------------------------------------------------------------------------------------
# Name: Conversão de Moedas
# Desc: Conversão de moedas para os padrões USD, BRL e EUR
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['STG.M.100.DataBaseUploads':'STG.M.100.DataBaseUploads':'Value' , 'ALL.D.Currency':'ALL.D.Currency':'Total Currency','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'STG.100.DataBase_Uploads', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'USD Conv.', !ALL.D.Region, !ALL.D.Products, !ALL.D.Accounts, !ALL.D.Account_Line, 'Value' ),
    DB( 'STG.100.DataBase_Uploads', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'BRL Conv.', !ALL.D.Region, !ALL.D.Products, !ALL.D.Accounts, !ALL.D.Account_Line, 'Value' ),
    DB( 'STG.100.DataBase_Uploads', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'EUR Conv.', !ALL.D.Region, !ALL.D.Products, !ALL.D.Accounts, !ALL.D.Account_Line, 'Value' );


    
