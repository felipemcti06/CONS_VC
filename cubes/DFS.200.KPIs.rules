                                     , 'ALL.D.Month':'YTD 12'
                                    , !ALL.D.Version
                                    , !ALL.D.Currency
                                     , !ALL.D.Region
                                     , !ALL.D.Products
                                     , 'Petcoke Price (LMU/t)','Value' );

