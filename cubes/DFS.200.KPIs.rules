# Name IFRS16
# Desc IFRS16
# Date 02/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.D.KPI':'DFS.D.KPI':'IFRS16','DFS.M.200.KPIs':'DFS.M.200.KPIs':'Value' ,  'ALL.D.Products':'ALL.D.Products':'PROD099'] =N:
  DB( 'DFS.180.Gross_Debt', 
            !ALL.D.Year, 
            !ALL.D.Month, 
            !ALL.D.Version, 
            !ALL.D.Currency, 
            !ALL.D.Region, 
            'Closing Balance Debt',
            'Value');


