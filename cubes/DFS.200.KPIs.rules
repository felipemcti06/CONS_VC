['DFS.D.KPI':'DFS.D.KPI':'Sust. Cash Flow in Hard Currency','DFS.M.200.KPIs':'DFS.M.200.KPIs':'Value','ALL.D.Region':'ALL.D.Region':'Global' , 'ALL.D.Products':'ALL.D.Products':'Total Products'] = C:
  IF(SCAN( 'Conv.', !ALL.D.Currency ) <> 0
  ,  DB('DFS.140.Indirect_Cash_Flow', 
                !ALL.D.Year, 
                !ALL.D.Month, 
                !ALL.D.Version, 
                !ALL.D.Currency, 
                'ALL.D.Region':'Hard Currency', 
                'Sustainable Cash Flow', 
                'DFS.M.140.Indirect_Cash_Flow':'Total Value' )
  \
   DB('DFS.140.Indirect_Cash_Flow', 
                !ALL.D.Year, 
                !ALL.D.Month, 
                !ALL.D.Version, 
                !ALL.D.Currency, 
               'ALL.D.Region':'Global', 
                'Sustainable Cash Flow', 
                'DFS.M.140.Indirect_Cash_Flow':'Total Value' )
  ,0 ); 
