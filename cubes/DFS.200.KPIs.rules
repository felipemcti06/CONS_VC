['DFS.D.KPI':'DFS.D.KPI':{'IFRS16','Depreciação LTM','Income Tax LTM','Equity LTM'
    ,'(+) Gross Fixed Assets','(-) Accumulated Depreciation','(+) Adjustment Hyperinflation','(+) Inflation adjustment','(+) Right of Use','(+) Investments','(+) Goodwill','(+) Intangible','% ROIC'},
 'ALL.D.Month':'ALL.D.Month':{'Total Months','1st Quarter','2nd Quarter','3rd Quarter','4th Quarter','1st Semester','2nd Semester'
,'YTD 01','YTD 02','YTD 03','YTD 04','YTD 05','YTD 06','YTD 07','YTD 08','YTD 09','YTD 10','YTD 11','YTD 12'},'DFS.M.200.KPIs':'DFS.M.200.KPIs':'Value'
]=C: 
  DB('DFS.200.KPIs', 
         !ALL.D.Year, 
         DB('}ElementAttributes_ALL.D.Month', !ALL.D.Month, 'Aux Totalizadores'), 
         !ALL.D.Version, 
         !ALL.D.Currency, 
         !ALL.D.Region, 
         !ALL.D.Products,
          !DFS.D.KPI,
         !DFS.M.200.KPIs );

