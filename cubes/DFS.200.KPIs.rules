['DFS.D.KPI':'DFS.D.KPI':'Depreciação LTM','ALL.D.Month':'ALL.D.Month':'01','DFS.M.200.KPIs':'DFS.M.200.KPIs':'Value']= N:
    DB('DFS.100.Profit_and_Loss', 
               !ALL.D.Year, 
               !ALL.D.Month, 
               !ALL.D.Version, 
               !ALL.D.Currency, 
               !ALL.D.Region, 
