['DFS.D.KPI':'DFS.D.KPI':'Receita adjacências','DFS.M.200.KPIs':'DFS.M.200.KPIs':'Value'] = N:
 IF(ELISANC( 'ALL.D.Products', 'Cement Group', !ALL.D.Products ) <> 0
    % ELISANC( 'ALL.D.Products', 'Group Others', !ALL.D.Products ) <> 0
  ,0  
  ,DB('DFS.200.KPIs', 
           !ALL.D.Year, 
           !ALL.D.Month, 
           !ALL.D.Version, 
           !ALL.D.Currency, 
           !ALL.D.Region, 
           !ALL.D.Products, 
           'Revenue', 
           'Value' ));    

