# --------------------------------------------------------------------------------------------  
['DFS.D.KPI':'DFS.D.KPI':'EBITDA in Hard Currency','DFS.M.200.KPIs':'DFS.M.200.KPIs':'Value','ALL.D.Region':'ALL.D.Region':'Global'] = C:
  IF(SCAN( 'Conv.', !ALL.D.Currency ) <> 0
  , DB('DFS.100.Profit_and_Loss', 
                !ALL.D.Year, 
                !ALL.D.Month, 
                !ALL.D.Version, 
                !ALL.D.Currency, 
                'ALL.D.Region':'Hard Currency', 
                !ALL.D.Products, 
                'EBITDA', 
                'DFS.M.100.Profit_and_Loss':'Total Value' )
  \
   DB('DFS.100.Profit_and_Loss', 
                !ALL.D.Year, 
                !ALL.D.Month, 
                !ALL.D.Version, 
                !ALL.D.Currency, 
                'ALL.D.Region':'Global', 
                !ALL.D.Products, 
                'EBITDA', 
                'DFS.M.100.Profit_and_Loss':'Total Value' )
  ,0 ); 



