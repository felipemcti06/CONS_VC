# --------------------------------------------------------------------------------------------
['DFS.D.KPI':'DFS.D.KPI':'NOPAT + Equity Pick Up','DFS.M.200.KPIs':'DFS.M.200.KPIs':'Value'] =N:
    DB('DFS.100.Profit_and_Loss', 
           !ALL.D.Year, 
           !ALL.D.Month, 
           !ALL.D.Version, 
           !ALL.D.Currency, 
           !ALL.D.Region, 
           !ALL.D.Products, 
           'Income Tax',
           'DFS.M.100.Profit_and_Loss':'Total Value')
  +
      DB('DFS.100.Profit_and_Loss', 
           !ALL.D.Year, 
           !ALL.D.Month, 
           !ALL.D.Version, 
           !ALL.D.Currency, 
           !ALL.D.Region, 
           !ALL.D.Products, 
           'Equity Pickup',
           'DFS.M.100.Profit_and_Loss':'Total Value')
    +
      DB('DFS.200.KPIs', 
           !ALL.D.Year, 
           !ALL.D.Month, 
           !ALL.D.Version, 
           !ALL.D.Currency, 
           !ALL.D.Region, 
           !ALL.D.Products, 
           'EBIT' );

# --------------------------------------------------------------------------------------------
