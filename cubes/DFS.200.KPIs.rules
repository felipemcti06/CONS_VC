               'Depreciation',
                 'DFS.M.100.Profit_and_Loss':'Total Value'  );
# --------------------------------------------------------------------------------------------
# Name 
# Desc 
# Date 02/2026
# Author: Miranda / HelderDFS.100.Profit_and_Loss
# --------------------------------------------------------------------------------------------
['DFS.D.KPI':'DFS.D.KPI':'Depreciação LTM','ALL.D.Month':'ALL.D.Month':{'02','03','04','05','06','07','08','09','10','11','12'},'DFS.M.200.KPIs':'DFS.M.200.KPIs':'Value']= N:
  #   DB('DFS.100.Profit_and_Loss', 
  #              !ALL.D.Year, 
  #              !ALL.D.Month, 
  #              !ALL.D.Version, 
  #              !ALL.D.Currency, 
  #              !ALL.D.Region, 
  #              !ALL.D.Products, 
  #              'Depreciation',
  #               'DFS.M.100.Profit_and_Loss':'Total Value' )
  # +
  #     DB('DFS.200.KPIs', 
  #               !ALL.D.Year, 
  #                DB('SYS.200.Time_Travel', !ALL.D.Year, !ALL.D.Month, '-1','Mes'), 
  #               !ALL.D.Version, 
  #               !ALL.D.Currency, 
  #               !ALL.D.Region, 
  #               !ALL.D.Products, 
  #               !DFS.D.KPI, !DFS.M.200.KPIs );
   DB('DFS.100.Profit_and_Loss', 
              DB('SYS.200.Time_Travel',!ALL.D.Year,!ALL.D.Month,'-12','Ano'), 
              'ALL.D.Month':'YTD 12', 
              !ALL.D.Version, 
              !ALL.D.Currency, 
              !ALL.D.Region, 
              !ALL.D.Products, 
              'Depreciation' , 
              'DFS.M.100.Profit_and_Loss':'Total Value' )
   -
      DB('DFS.100.Profit_and_Loss', 
              DB('SYS.200.Time_Travel',!ALL.D.Year,!ALL.D.Month,'-12','Ano'), 
              'YTD ' | !ALL.D.Month, 
              !ALL.D.Version, 
              !ALL.D.Currency, 
              !ALL.D.Region, 
              !ALL.D.Products, 
              'Depreciation' , 
              'DFS.M.100.Profit_and_Loss':'Total Value' )
   +
         DB('DFS.100.Profit_and_Loss', 
              !ALL.D.Year, 
              'YTD ' | !ALL.D.Month, 
              !ALL.D.Version, 
              !ALL.D.Currency, 
              !ALL.D.Region, 
              !ALL.D.Products, 
              'Depreciation' , 
              'DFS.M.100.Profit_and_Loss':'Total Value' );
# --------------------------------------------------------------------------------------------
# Name 
# Desc 
# Date 02/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.D.KPI':'DFS.D.KPI':'Income Tax Theoretical','DFS.M.200.KPIs':'DFS.M.200.KPIs':'Value']=N:
    (DB('DFS.200.KPIs', 
            !ALL.D.Year, 
            !ALL.D.Month, 
            !ALL.D.Version, 
            !ALL.D.Currency, 
            !ALL.D.Region, 
            !ALL.D.Products, 'EBITDA LTM','Value')
     +
    DB('DFS.100.Profit_and_Loss', 
             !ALL.D.Year, 
             !ALL.D.Month, 
             !ALL.D.Version, 
             !ALL.D.Currency, 
             !ALL.D.Region, 
             !ALL.D.Products, 
               'Other Op. Results', 
               'DFS.M.100.Profit_and_Loss':'Total Value' )
     -
     DB('DFS.200.KPIs', 
            !ALL.D.Year, 
            !ALL.D.Month, 
            !ALL.D.Version, 
            !ALL.D.Currency, 
            !ALL.D.Region, 
            !ALL.D.Products, 'EBITDA LTM','Value')
      +
    DB('DFS.100.Profit_and_Loss', 
             !ALL.D.Year, 
             !ALL.D.Month, 
             !ALL.D.Version, 
             !ALL.D.Currency, 
             !ALL.D.Region, 
             !ALL.D.Products, 
               'DFS.D.Accounts_PnL':'Financial Results', 
              'Value')
      +
      
     DB('STG.100.DataBase_Uploads', 
     !ALL.D.Year, 
     !ALL.D.Month,
     !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     !ALL.D.Products,
     'Additions/Low IT Income Statement',
      'N/A', 
     'Value'))
    
    *
   DB( 'ALL.015.Region_Assumptions', 
       !ALL.D.Year, 
       !ALL.D.Month,
       !ALL.D.Version, 
       !ALL.D.Region,
       '% Income Tax Theoretical' ,'Value');
