['DFS.D.KPI':{'Thermal Sub. (%)','Thermal C. (kcal/t kk)','Fuel (LMU/t)','Package','Aux. Materials','Operacional Services','Internal Freight','Variavel maintenance','CO2 Gross (kg/ton)','CO2 Net (kg/ton)','Power Price (LMU/MWh)','Power Cons. (kWh/t)',
'Clinker Factor (%)','Power (LMU/t)','Raw Material (LMU/t)','Other Variable (LMU/t)','Labor (LMU/t)','Maintenance (LMU/t)','Other Fixed Costs (LMU/t)','Cash Cost (LMU/t)','Cement Var. Costs (LMU/t)','Cement Fix. Costs (LMU/t)'},'ALL.D.Month':'ALL.D.Month':{'Year','1st Quarter','2nd Quarter','3rd Quarter','4th Quarter','1st Semester','2nd Semester',
