# --------------------------------------------------------------------------------------------
#
#                      			INICIO DO BLOCO CALCULOS 
#
# --------------------------------------------------------------------------------------------
# --------------------------------------------------------------------------------------------
# Name Define versões calculadas
# Desc A partir dessa regra só calcula para versões dinâmicas
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
[]=IF(ELISANC( 'ALL.D.Version', 'Dynamic Versions', !ALL.D.Version ) <> 0 
  % !ALL.D.Version@='RE' 
  ,CONTINUE
  ,STET
  ); 

[]=IF(
  ELISANC( 'ALL.D.Version', 'Dynamic Versions', !ALL.D.Version ) <> 0 
  &
  DB( 'ALL.001.Actual_Control', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Flag' )@='ACTUAL',
        ['ALL.D.Version':'ALL.D.Version':'RE'],
        CONTINUE) ;


# --------------------------------------------------------------------------------------------
# Name 
# Desc 
# Date 02/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
 ['DFS.D.KPI':'DFS.D.KPI':'Production volume (kt)','DFS.M.200.KPIs':'DFS.M.200.KPIs':'Value'] =N:
  DB('STG.100.DataBase_Uploads', 
           !ALL.D.Year, 
           !ALL.D.Month, 
           !ALL.D.Version, 
           !ALL.D.Currency, 
           !ALL.D.Region, 
           !ALL.D.Products, 
            'Production volume (kt)',
            'N/A',
            'Value');
