# Desc 
# Date 02/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.D.KPI':'DFS.D.KPI':'EBIT','DFS.M.200.KPIs':'DFS.M.200.KPIs':'Value'] =N:
    DB('DFS.100.Profit_and_Loss', 
           !ALL.D.Year, 
           !ALL.D.Month, 
           !ALL.D.Version, 
           !ALL.D.Currency, 
           !ALL.D.Region, 
           !ALL.D.Products, 
           'Contribution Margin',
           'Value')
  +
      DB('DFS.100.Profit_and_Loss', 
           !ALL.D.Year, 
           !ALL.D.Month, 
           !ALL.D.Version, 
           !ALL.D.Currency, 
           !ALL.D.Region, 
           !ALL.D.Products, 
           'Fixed Costs',
           'Value')
  +
      DB('DFS.100.Profit_and_Loss', 
           !ALL.D.Year, 
           !ALL.D.Month, 
           !ALL.D.Version, 
           !ALL.D.Currency, 
           !ALL.D.Region, 
           !ALL.D.Products, 
           'Depreciation',
           'Value')
  +    
      DB('DFS.100.Profit_and_Loss', 
           !ALL.D.Year, 
           !ALL.D.Month, 
           !ALL.D.Version, 
           !ALL.D.Currency, 
           !ALL.D.Region, 
           !ALL.D.Products, 
           'Operational Expenses',
           'Value')
  +
        DB('DFS.100.Profit_and_Loss', 
           !ALL.D.Year, 
           !ALL.D.Month, 
           !ALL.D.Version, 
           !ALL.D.Currency, 
           !ALL.D.Region, 
           !ALL.D.Products, 
           'Other Op. Results',
           'Value');

# --------------------------------------------------------------------------------------------
# Name 
# Desc 
# Date 02/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.D.KPI':'DFS.D.KPI':'Invested Capital Avg','DFS.M.200.KPIs':'DFS.M.200.KPIs':'Value'] =N:
  (DB('DFS.200.KPIs', !ALL.D.Year, '01', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'DFS.D.KPI':'Assets' )
  +
DB('DFS.200.KPIs', !ALL.D.Year, '02', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'DFS.D.KPI':'Assets' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '03', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'DFS.D.KPI':'Assets' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '04', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'DFS.D.KPI':'Assets' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '05', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'DFS.D.KPI':'Assets' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '06', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'DFS.D.KPI':'Assets' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '07', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'DFS.D.KPI':'Assets' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '08', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'DFS.D.KPI':'Assets' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '09', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'DFS.D.KPI':'Assets' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '10', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'DFS.D.KPI':'Assets' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '11', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'DFS.D.KPI':'Assets' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '12', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'DFS.D.KPI':'Assets' ))
  /12
  +
    (DB('DFS.200.KPIs', !ALL.D.Year, '01', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'DFS.D.KPI':'Working Capital Balance' )
  +
DB('DFS.200.KPIs', !ALL.D.Year, '02', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products,  'DFS.D.KPI':'Working Capital Balance' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '03', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products, 'DFS.D.KPI':'Working Capital Balance' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '04', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products,  'DFS.D.KPI':'Working Capital Balance')
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '05', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products,  'DFS.D.KPI':'Working Capital Balance' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '06', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products,  'DFS.D.KPI':'Working Capital Balance' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '07', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products,  'DFS.D.KPI':'Working Capital Balance')
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '08', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products,  'DFS.D.KPI':'Working Capital Balance' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '09', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products,  'DFS.D.KPI':'Working Capital Balance')
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '10', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products,  'DFS.D.KPI':'Working Capital Balance' )
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '11', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products,  'DFS.D.KPI':'Working Capital Balance')
  +
  DB('DFS.200.KPIs', !ALL.D.Year, '12', !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, !ALL.D.Products,  'DFS.D.KPI':'Working Capital Balance' ))
  /12;

