# --------------------------------------------------------------------------------------------
# Name 
# Desc: Abertura por Moculo
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['ALL.M.004.Uploads_Status_Planning':'ALL.M.004.Uploads_Status_Planning':'Status'] = S:
  IF( DB( 'ALL.100.Assumptions_Upload', 'Current Planning Module', 'Value' )@<>!ALL.D.Planning_Module ,
  'Closed',
  CONTINUE

  );




# --------------------------------------------------------------------------------------------
# Name  : Aux_Date_Closed
# Desc  : Monta timestamp da data de fechamento informada pelo usuário
# Date  : 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------

['ALL.M.004.Uploads_Status_Planning':'ALL.M.004.Uploads_Status_Planning':'Aux_Date_Closed'] = S:

    IF(
        DB('ALL.004.Uploads_Status_Planning', !ALL.D.Version, !ALL.D.Region,!ALL.D.Planning_Module, 'Date Closed') @<> '',

        TimSt(Now,'\Y')

        | Subst(
            DB('ALL.004.Uploads_Status_Planning', !ALL.D.Version, !ALL.D.Region,!ALL.D.Planning_Module, 'Date Closed'),
            4,2
          )

        | Subst(
            DB('ALL.004.Uploads_Status_Planning', !ALL.D.Version, !ALL.D.Region,!ALL.D.Planning_Module, 'Date Closed'),
            1,2
          )

        | DB(
            'ALL.004.Uploads_Status_Planning',
            !ALL.D.Version,
            !ALL.D.Region,!ALL.D.Planning_Module,
            'Hour Closed'
          ),

        ''
    );


# --------------------------------------------------------------------------------------------
# Name  : Aux_Date_System
# Desc  : Timestamp atual do sistema para comparação com a data de fechamento
# Date  : 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------

['ALL.M.004.Uploads_Status_Planning':'ALL.M.004.Uploads_Status_Planning':'Aux_Date_System'] = S:

    IF(
        DB('ALL.004.Uploads_Status_Planning', !ALL.D.Version, !ALL.D.Region,!ALL.D.Planning_Module, 'Date Closed') @<> '',

        TimSt(Now,'\Y')
        | TimSt(Now,'\m')
        | TimSt(Now,'\d')
        | TRIM(
            STR(
                NUMBR(TimSt(Now,'\h')) - 3,
                4,
                0
            )
          ),

        ''
    );


# --------------------------------------------------------------------------------------------
# Name  : Status
# Desc  : Determina o status de abertura ou fechamento do planejamento
# Date  : 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------


# --------------------------------------------------------------------------------------------
# Regra 1
# Herda status da região definida no mapeamento (H2 Level 1)
# --------------------------------------------------------------------------------------------

['ALL.M.004.Uploads_Status_Planning':'ALL.M.004.Uploads_Status_Planning':'Status'] = S:

    IF(
        DB(
            'ALL.004.Uploads_Status_Planning',
            !ALL.D.Version,
            DB('MAP.030.Region', !ALL.D.Region,!ALL.D.Planning_Module, 'H2 Level 1'),
            'Status'
        ) @<> ''

        &
        DB(
            'ALL.004.Uploads_Status_Planning',
            !ALL.D.Version,
            !ALL.D.Region,!ALL.D.Planning_Module,
            'Date Closed'
        ) @= '',

        DB(
            'ALL.004.Uploads_Status_Planning',
            !ALL.D.Version,
            DB('MAP.030.Region', !ALL.D.Region,!ALL.D.Planning_Module, 'H2 Level 1'),
            'Status'
        ),

        CONTINUE
    );


# --------------------------------------------------------------------------------------------
# Regra 2
# Herda status do pai nível 2 da hierarquia
# --------------------------------------------------------------------------------------------

['ALL.M.004.Uploads_Status_Planning':'ALL.M.004.Uploads_Status_Planning':'Status'] = S:

    IF(
        DB(
            'ALL.004.Uploads_Status_Planning',
            !ALL.D.Version,
            ELPAR('ALL.D.Region', !ALL.D.Region, 2),
            'Status'
        ) @<> ''

        &
        DB(
            'ALL.004.Uploads_Status_Planning',
            !ALL.D.Version,
            !ALL.D.Region,!ALL.D.Planning_Module,
            'Date Closed'
        ) @= '',

        DB(
            'ALL.004.Uploads_Status_Planning',
            !ALL.D.Version,
            ELPAR('ALL.D.Region', !ALL.D.Region, 2),
            'Status'
        ),

        CONTINUE
    );


# --------------------------------------------------------------------------------------------
# Regra 3
# Herda status do pai nível 1 da hierarquia
# --------------------------------------------------------------------------------------------

['ALL.M.004.Uploads_Status_Planning':'ALL.M.004.Uploads_Status_Planning':'Status'] = S:

    IF(
        DB(
            'ALL.004.Uploads_Status_Planning',
            !ALL.D.Version,
            ELPAR('ALL.D.Region', !ALL.D.Region, 1),
            'Status'
        ) @<> ''

        &
        DB(
            'ALL.004.Uploads_Status_Planning',
            !ALL.D.Version,
            !ALL.D.Region,!ALL.D.Planning_Module,
            'Date Closed'
        ) @= '',

        DB(
            'ALL.004.Uploads_Status_Planning',
            !ALL.D.Version,
            ELPAR('ALL.D.Region', !ALL.D.Region, 1),
            'Status'
        ),

        CONTINUE
    );


# --------------------------------------------------------------------------------------------
# Regra 4
# Fecha o status quando a data de sistema for igual à data de fechamento
# e houver submissões válidas
# --------------------------------------------------------------------------------------------

['ALL.M.004.Uploads_Status_Planning':'ALL.M.004.Uploads_Status_Planning':'Status'] = S:

    IF(
        DB('ALL.004.Uploads_Status_Planning', !ALL.D.Version, !ALL.D.Region,!ALL.D.Planning_Module, 'Date Closed') @<> '',

        IF(
            TRIM(DB('ALL.004.Uploads_Status_Planning', !ALL.D.Version, !ALL.D.Region,!ALL.D.Planning_Module, 'Aux_Date_System'))
            @=
            TRIM(DB('ALL.004.Uploads_Status_Planning', !ALL.D.Version, !ALL.D.Region,!ALL.D.Planning_Module, 'Aux_Date_Closed'))

            &
            DB('ALL.004.Uploads_Status_Planning', !ALL.D.Version, !ALL.D.Region,!ALL.D.Planning_Module, 'Submission Count') > 0

            &
            DB('ALL.004.Uploads_Status_Planning', !ALL.D.Version, !ALL.D.Region,!ALL.D.Planning_Module, 'Reopen Count')
            <
            DB('ALL.004.Uploads_Status_Planning', !ALL.D.Version, !ALL.D.Region,!ALL.D.Planning_Module, 'Submission Count'),

            'Closed',

            CONTINUE
        ),

        CONTINUE
    );


# --------------------------------------------------------------------------------------------
# Regra 5
# Fecha quando a data do sistema for maior que a data de fechamento
# --------------------------------------------------------------------------------------------

['ALL.M.004.Uploads_Status_Planning':'ALL.M.004.Uploads_Status_Planning':'Status'] = S:

    IF(
        TRIM(DB('ALL.004.Uploads_Status_Planning', !ALL.D.Version, !ALL.D.Region,!ALL.D.Planning_Module, 'Aux_Date_System'))
        @>
        TRIM(DB('ALL.004.Uploads_Status_Planning', !ALL.D.Version, !ALL.D.Region,!ALL.D.Planning_Module, 'Aux_Date_Closed')),

        'Closed',

        CONTINUE
    );


# --------------------------------------------------------------------------------------------
# Regra Final
# Versão atual do planning permanece aberta
# --------------------------------------------------------------------------------------------

['ALL.M.004.Uploads_Status_Planning':'ALL.M.004.Uploads_Status_Planning':'Status'] = S:

    IF(
        DB('ALL.100.Assumptions_Upload', 'Current Version Planning', 'Value')
        @=
        ATTRS('ALL.D.Version', !ALL.D.Version, 'Descrição'),

        'Open',

        'Closed'
    );