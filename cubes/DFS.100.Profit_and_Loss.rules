 #       '% Income Tax', 'Value' )
 #    ;
  DB('STG.100.DataBase_Uploads', 
     !ALL.D.Year, 
     !ALL.D.Month,
     !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     !ALL.D.Products,
     'Income Tax',
      'ALL.D.Account_Line':'Total Accounts Line', 
     'Value'
);
# --------------------------------------------------------------------------------------------
# Name:  Income Tax
# Desc:   Income Tax
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'% Income Tax' , 'DFS.M.100.Profit_and_Loss':'DFS.M.100.Profit_and_Loss':'Value'] =
    ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Income Tax']
    \
    ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Profit Before Income Tax'];
# --------------------------------------------------------------------------------------------
# Name:  Income Tax Adjustments
# Desc:   Income Tax Adjustments
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Income Tax' , 'DFS.M.100.Profit_and_Loss':'DFS.M.100.Profit_and_Loss':'Adjustments'] = N: 
(
     ( ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'EBITDA']
    +
    ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Other Non Op. Results']
       +
   ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Depreciation']
    +
   ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Financial Results'] )
    *
   DB( 'ALL.015.Region_Assumptions', 
       !ALL.D.Year, 
       !ALL.D.Month,
       !ALL.D.Version, 
       !ALL.D.Region,
       '% Income Tax', 'Value' )
  )
    ;


# --------------------------------------------------------------------------------------------
# Name:  Net Profit Before Minority Int.
# Desc:   Net Profit Before Minority Int.
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Net Profit Before Minority Int.', 'DFS.M.100.Profit_and_Loss':'DFS.M.100.Profit_and_Loss':{'Value', 'Adjustments'}] = N:
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Profit Before Income Tax']
    -
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Income Tax']  
;



# --------------------------------------------------------------------------------------------
# Name:  Minority Interests
# Desc:   Minority Interests
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Minority Interests', 'DFS.M.100.Profit_and_Loss':'DFS.M.100.Profit_and_Loss':{'Value', 'Adjustments'}] = N:
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Net Profit Before Minority Int.']
    *
     DB( 'ALL.015.Region_Assumptions', 
       !ALL.D.Year, 
       !ALL.D.Month,
       !ALL.D.Version, 
       !ALL.D.Region,
       '% Minoritários', 'Value' )
;


# --------------------------------------------------------------------------------------------
# Name:  Net Profit 
# Desc:   Net Profit
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Net Profit', 'DFS.M.100.Profit_and_Loss':'DFS.M.100.Profit_and_Loss':{'Value', 'Adjustments'}] = N:
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Net Profit Before Minority Int.']
    -
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Minority Interests']  
;

# --------------------------------------------------------------------------------------------
# Name:  EBITDA Econômico
# Desc:   EBITDA Econômico
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'EBITDA Econômico', 'DFS.M.100.Profit_and_Loss':'DFS.M.100.Profit_and_Loss':{'Value', 'Adjustments'}] = N:
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'EBITDA']
    *
  DB( 'ALL.015.Region_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Region, '% Participation', 'Value' )
;


# --------------------------------------------------------------------------------------------
#
#                      			INICIO DO BLOCO CALCULOS RESULTADO FINANCEIRO
#
# --------------------------------------------------------------------------------------------


