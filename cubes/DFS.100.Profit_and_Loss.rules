  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Profit Before Income Tax', 'DFS.M.100.Profit_and_Loss':'DFS.M.100.Profit_and_Loss':{'Value', 'Adjustments'}] = N:
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Operating Profit']
    +
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Financial Results']  
      +
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Equity Pickup']  
      +
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Other Non Op. Results']  ;




