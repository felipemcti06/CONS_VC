# --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Financial Expenses' ,'ALL.D.Products':'ALL.D.Products':'PROD099'] = N:
    DB( 'DFS.120.Financial_Results',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        !ALL.D.Currency,
        !ALL.D.Region,
        'DFS.D.Accounts_Fin_Results':'Financial Expenses',
        !DFS.M.100.Profit_and_Loss
      );




# --------------------------------------------------------------------------------------------
# Name: Financial Revenues
# Desc: Financial Revenues
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Financial Revenues' ,'ALL.D.Products':'ALL.D.Products':'PROD099'] = N:
    DB( 'DFS.120.Financial_Results',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        !ALL.D.Currency,
        !ALL.D.Region,
        'DFS.D.Accounts_Fin_Results':'Total Financial Revenues',
        !DFS.M.100.Profit_and_Loss
      );



    

# --------------------------------------------------------------------------------------------
# Name: FX Variation
# Desc: FX Variation
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'FX Variation' ,'ALL.D.Products':'ALL.D.Products':'PROD099'] = N:
    DB( 'DFS.120.Financial_Results',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        !ALL.D.Currency,
        !ALL.D.Region,
        'DFS.D.Accounts_Fin_Results':'Total Foreign Exchange Variation',
        !DFS.M.100.Profit_and_Loss
      );



# --------------------------------------------------------------------------------------------
# Name: Others
# Desc: Others
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Others' ,'ALL.D.Products':'ALL.D.Products':'PROD099'] = N:
    DB( 'DFS.120.Financial_Results',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        !ALL.D.Currency,
        !ALL.D.Region,
        'DFS.D.Accounts_Fin_Results':'Total Hedge Results',
        !DFS.M.100.Profit_and_Loss
      )
    +
        DB( 'DFS.120.Financial_Results',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        !ALL.D.Currency,
        !ALL.D.Region,
        'DFS.D.Accounts_Fin_Results':'Total Other Financial Revenues',
        !DFS.M.100.Profit_and_Loss
      );

# --------------------------------------------------------------------------------------------
# Name EBITDA FX
# Desc EBITDA FX
# Date 02/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'EBITDA FX' , 'DFS.M.100.Profit_and_Loss':'DFS.M.100.Profit_and_Loss':'Value' , 'ALL.D.Currency':'ALL.D.Currency':'BRL Conv.']=N:
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'EBITDA' , 'ALL.D.Currency':'ALL.D.Currency':'USD Conv.']
  *
  DB( 'ALL.010.Economic_Assumptions', 
      !ALL.D.Year,
      !ALL.D.Month,
      !ALL.D.Version,
      'EBITDA FX R$/US$',
      'ALL.M.010.Economic_Assumptions':'Value' )
  ;

