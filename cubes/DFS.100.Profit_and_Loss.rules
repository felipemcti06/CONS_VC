# =============
  FEEDERS;
# =============
# # --------------------------------------------------------------------------------------------
# # Name: Feedes Forecast 
# # Desc: Feedes Forecast 
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
 ['ALL.D.Version':'ALL.D.Version':'RE'] => ['ALL.D.Version':'ALL.D.Version':'Dynamic Versions'];

# --------------------------------------------------------------------------------------------
# Name: Conversão de Moedas
# Desc: Conversão de moedas para os padrões USD, BRL e EUR
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.M.100.Profit_and_Loss':'DFS.M.100.Profit_and_Loss':'Adjustments', 'ALL.D.Currency':'ALL.D.Currency':'Total Currency','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'DFS.100.Profit_and_Loss', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'BRL Conv.', !ALL.D.Region, !ALL.D.Products, !DFS.D.Accounts_PnL, 'Adjustments' ),
    DB( 'DFS.100.Profit_and_Loss', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'EUR Conv.', !ALL.D.Region, !ALL.D.Products, !DFS.D.Accounts_PnL, 'Adjustments' ),
    DB( 'DFS.100.Profit_and_Loss', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'USD Conv.', !ALL.D.Region, !ALL.D.Products, !DFS.D.Accounts_PnL, 'Adjustments' )
    
    ;



