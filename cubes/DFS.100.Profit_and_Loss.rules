  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Operating Profit', 'DFS.M.100.Profit_and_Loss':'DFS.M.100.Profit_and_Loss':{'Value', 'Adjustments'}] =N: 
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'EBITDA']
    +
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Depreciation']
