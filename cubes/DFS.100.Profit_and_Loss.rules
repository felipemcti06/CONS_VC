# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
  ['DFS.D.Accounts_PnL':'DFS.D.Accounts_PnL':'Interest Accrual' ,'ALL.D.Products':'ALL.D.Products':'PROD099'] = N:
    DB( 'DFS.120.Financial_Results',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        !ALL.D.Currency,
        !ALL.D.Region,
        'Accrual of Interest (LC)',
        !DFS.M.100.Profit_and_Loss
      );




