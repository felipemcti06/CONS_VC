# =============
  FEEDERS;
# =============



	
# # --------------------------------------------------------------------------------------------
# # Name: Feedes Forecast 
# # Desc: Feedes Forecast 
# # Date 01/2026
# # Author: Miranda / Helder
# # --------------------------------------------------------------------------------------------
 ['ALL.D.Version':'ALL.D.Version':'RE'] => ['ALL.D.Version':'ALL.D.Version':'Dynamic Versions'];



# --------------------------------------------------------------------------------------------
# Name: Conversão de Moedas
# Desc: Conversão de moedas para os padrões USD, BRL e EUR
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.M.180.Gross_Debt':'DFS.M.180.Gross_Debt':'Adjustments', 'ALL.D.Currency':'ALL.D.Currency':'Total Currency','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>DB( 'DFS.180.Gross_Debt', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'BRL Conv.', !ALL.D.Region, !DFS.D.Accounts_Debt, !DFS.M.180.Gross_Debt ) ,
    DB( 'DFS.180.Gross_Debt', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'EUR Conv.', !ALL.D.Region, !DFS.D.Accounts_Debt, !DFS.M.180.Gross_Debt ) ,
    DB( 'DFS.180.Gross_Debt', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'USD Conv.', !ALL.D.Region, !DFS.D.Accounts_Debt, !DFS.M.180.Gross_Debt ) 
    

    ;
    
# --------------------------------------------------------------------------------------------
# Name:Foreign Exchange Variation
# Desc: Foreign Exchange Variation
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Initial Gross Debt'  ,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Foreign Exchange Variation'];

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt' ,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Foreign Exchange Variation'];


    
# --------------------------------------------------------------------------------------------
# Name:Closing Balance Debt
# Desc: Closing Balance Debt
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------


['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Initial Gross Debt','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt'];

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Funding','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt'];

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Accrual of Interest','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt'];

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Monetary Variation','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt'];

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Principal Amortization','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt'];

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Interest Amortization','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt'];    

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Other Variation','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt'];        

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Variation by buy/sale of company','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt'];     

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Foreign Exchange Variation','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt'];         
    
['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt'
 ,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=> 
  DB( 'DFS.180.Gross_Debt',
       DB( 'SYS.200.Time_Travel', !ALL.D.Year, !ALL.D.Month, '1', 'Ano' )  ,
      DB( 'SYS.200.Time_Travel', !ALL.D.Year, !ALL.D.Month, '1', 'Mes' ) ,
      !ALL.D.Version,
      !ALL.D.Currency,
      !ALL.D.Region,
      'Initial Gross Debt',
      !DFS.M.180.Gross_Debt
    );

   
