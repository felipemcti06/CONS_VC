# --------------------------------------------------------------------------------------------
# Name: Funding
# Desc: Funding
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.M.180.Gross_Debt':'DFS.M.180.Gross_Debt':'Value' , 'DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Funding']=N:
    DB('STG.100.DataBase_Uploads', 
     !ALL.D.Year, 
     !ALL.D.Month,
     !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     'ALL.D.Products':'Total Products',
     'Funding (LC)',
      'ALL.D.Account_Line':'Total Accounts Line', 
     'Value'
);

