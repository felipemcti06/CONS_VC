# --------------------------------------------------------------------------------------------
# Name:Closing Balance Debt
# Desc:Closing Balance Debt
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
[ 'DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt']=N:
['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Initial Gross Debt']
+
['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Funding']
+
['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Accrual of Interest']
  +
['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Monetary Variation']
  +
['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Principal Amortization']
  +
['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Interest Amortization']
  +
['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Other Variation']
  +
['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Variation by buy/sale of company'];
