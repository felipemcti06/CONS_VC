# --------------------------------------------------------------------------------------------
['DFS.M.180.Gross_Debt':'DFS.M.180.Gross_Debt':'Value' , 'DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Accrual of Interest']=N:
    DB('STG.100.DataBase_Uploads', 
     !ALL.D.Year, 
     !ALL.D.Month,
     !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     'ALL.D.Products':'Total Products',
     'Accrual of Interest (LC)',
      'ALL.D.Account_Line':'Total Accounts Line', 
     'Value'
);

