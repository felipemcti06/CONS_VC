# Desc: Closing Balance Debt Leasing
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------


['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Initial Gross Debt Leasing','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt Leasing'];

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Funding Leasing','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt Leasing'];

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Accrual of Interest Leasing','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt Leasing'];

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Monetary Variation Leasing','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt Leasing'];

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Principal Amortization Leasing','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt Leasing'];

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Interest Amortization Leasing','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt Leasing'];

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Other Variation Leasing','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt Leasing'];        

['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Variation by buy/sale of company Leasing','ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=>['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt Leasing'];


    
['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt Leasing'
 ,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' }
]=> 
  DB( 'DFS.180.Gross_Debt',
       DB( 'SYS.200.Time_Travel', !ALL.D.Year, !ALL.D.Month, '1', 'Ano' )  ,
      DB( 'SYS.200.Time_Travel', !ALL.D.Year, !ALL.D.Month, '1', 'Mes' ) ,
      !ALL.D.Version,
      !ALL.D.Currency,
      !ALL.D.Region,
      'Initial Gross Debt Leasing',
      !DFS.M.180.Gross_Debt
    );


    
