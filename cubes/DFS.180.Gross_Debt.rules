['DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Closing Balance Debt Total'
 ,'ALL.D.Version':'ALL.D.Version':{ 'Dynamic Versions' , 'RE' } 
]=> DB( 'DFS.140.Indirect_Cash_Flow', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, !ALL.D.Currency, !ALL.D.Region, 'Final Debt Position', !DFS.M.180.Gross_Debt);


