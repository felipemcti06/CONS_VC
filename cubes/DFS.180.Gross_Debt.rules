# =============
  SKIPCHECK;
  FEEDSTRINGS;
# =============


# --------------------------------------------------------------------------------------------
# Name:Closing Balance Debt
# Desc:Closing Balance Debt
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
[ 'DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':{'Closing Balance Debt', 'Closing Balance Debt Leasing' , 'Closing Balance Debt Total'}]=
    IF( DTYPE( 'ALL.D.Month', !ALL.D.Month )@='C', 
  DB( 'DFS.180.Gross_Debt', 
      !ALL.D.Year ,
      DB('}ElementAttributes_ALL.D.Month', !ALL.D.Month, 'Aux Totalizadores'),
      !ALL.D.Version,
      !ALL.D.Currency,
      !ALL.D.Region,
      'DFS.D.Accounts_Debt':'Closing Balance Debt',
      'DFS.M.180.Gross_Debt':'Total Value'
    )
    , CONTINUE );


# --------------------------------------------------------------------------------------------
# Name: Initial Gross Debt
# Desc: Initial Gross Debt
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------

[ 'DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt': { 'Initial Gross Debt' , 'Initial Gross Debt Leasing' , 'Initial Gross Debt Total' }]=
    IF( DTYPE( 'ALL.D.Month', !ALL.D.Month )@='C', 
  DB( 'DFS.180.Gross_Debt', 
      !ALL.D.Year ,
      DB('}ElementAttributes_ALL.D.Month', !ALL.D.Month, 'Aux Totalizadores Inicial'),
      !ALL.D.Version,
      !ALL.D.Currency,
      !ALL.D.Region,
      'DFS.D.Accounts_Debt':'Initial Gross Debt',
      'DFS.M.180.Gross_Debt':'Total Value'
    )
    , CONTINUE );


# --------------------------------------------------------------------------------------------
# Name Define versões calculadas
# Desc A partir dessa regra só calcula para versões dinâmicas
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
[]=IF(ELISANC( 'ALL.D.Version', 'Dynamic Versions', !ALL.D.Version ) <> 0 % !ALL.D.Version@='RE' 
  ,CONTINUE
  ,STET
  ); 
[]=IF(ELISANC( 'ALL.D.Version', 'Dynamic Versions', !ALL.D.Version ) <> 0 
  &
  DB( 'ALL.001.Actual_Control', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Flag' )@='ACTUAL',
        ['ALL.D.Version':'ALL.D.Version':'RE'],
        CONTINUE) ;

# --------------------------------------------------------------------------------------------
#
#                      			INICIO DO BLOCO CALCULOS CONVERSÃO MOEDA SALDO INICIAL E SALDO FINAL
#
# --------------------------------------------------------------------------------------------
# --------------------------------------------------------------------------------------------
# Name: Conversão de Moedas
# Desc: Conversão de moedas para os padrões USD, BRL e EUR
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------

###############################################################
#-------------------------------------# USD CONV #-----------------------------------------
###############################################################

#-------------------------------------# VALOR INICIAL  #-----------------------------------------
  ['ALL.D.Currency':'ALL.D.Currency':'USD Conv.', 
   'DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':{'Initial Gross Debt' , 'Initial Gross Debt Leasing' }
  ] = N:

  #USD  
  ['ALL.D.Currency':'ALL.D.Currency':'USD']
     +
  # BRL PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'BRL'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX R$/US$', 'Value' )

+         
  #   EUR PARA USD  
 ['ALL.D.Currency':'ALL.D.Currency':'EUR'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX US$/EUR', 'Value' )
                                              
      +
  # ARS PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'ARS'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX ARS$/US$', 'Value' )  
      +
  # BOB  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'BOB'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX BOB$/US$', 'Value' )  
      +
  # CAD  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'CAD'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX CAD$/US$', 'Value' )  

          +
  # TRY  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'TRY'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX TRY$/US$', 'Value' )  

     +
 # UYU PARA USD  
  ['ALL.D.Currency':'ALL.D.Currency':'UYU'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX UYU$/US$', 'Value' )  
    ;


#-------------------------------------# VALOR FINAL  #-----------------------------------------
  ['ALL.D.Currency':'ALL.D.Currency':'USD Conv.', 'DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':{'Closing Balance Debt' , 'Closing Balance Debt Leasing'} ] = N:

  #USD  
  ['ALL.D.Currency':'ALL.D.Currency':'USD']
     +
  # BRL PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'BRL'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )

+         
  #   EUR PARA USD  
 ['ALL.D.Currency':'ALL.D.Currency':'EUR'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
                                              
      +
  # ARS PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'ARS'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX ARS$/US$', 'Value' )  
      +
  # BOB  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'BOB'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX BOB$/US$', 'Value' )  
      +
  # CAD  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'CAD'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX CAD$/US$', 'Value' )  

          +
  # TRY  PARA USD 
  ['ALL.D.Currency':'ALL.D.Currency':'TRY'] \  DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX TRY$/US$', 'Value' )  

     +
 # UYU PARA USD  
  ['ALL.D.Currency':'ALL.D.Currency':'UYU'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX UYU$/US$', 'Value' )  
    ;

###############################################################
#-------------------------------------# BRL CONV #-----------------------------------------
###############################################################



#-------------------------------------# VALOR INICIAL  #-----------------------------------------
  ['ALL.D.Currency':'ALL.D.Currency':'BRL Conv.' , 'DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':{ 'Initial Gross Debt'  , 'Initial Gross Debt Leasing' }] = N:
  #    #BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'BRL']
     +
  #  USD PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'USD'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX R$/US$', 'Value' )

+         
  #   EUR PARA BRL  
 ['ALL.D.Currency':'ALL.D.Currency':'EUR'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX US$/EUR', 'Value' )
                                              *DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX R$/US$', 'Value' )

    
    +
  #  ARS PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'ARS'] * 
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX ARS$/US$', 'Value' ) )
    +
  #  BOB PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'BOB'] * 
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX BOB$/US$', 'Value' ) )
        +
  #  CAD PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'CAD'] *
      (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX CAD$/US$', 'Value' ) )

            +
  #  TRY PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'TRY'] *
      (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX TRY$/US$', 'Value' ) )

      +
    # UYU PARA BRL
  ['ALL.D.Currency':'ALL.D.Currency':'UYU'] * 
    
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX UYU$/US$', 'Value' ) )
    ;



#-------------------------------------# VALOR FINAL  #-----------------------------------------
  ['ALL.D.Currency':'ALL.D.Currency':'BRL Conv.' , 'DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':{ 'Closing Balance Debt' , 'Closing Balance Debt Leasing'} ] = N:
  #    #BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'BRL']
     +
  #  USD PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'USD'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )

+         
  #   EUR PARA BRL  
 ['ALL.D.Currency':'ALL.D.Currency':'EUR'] * DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
                                              *DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )

    
    +
  #  ARS PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'ARS'] * 
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX ARS$/US$', 'Value' ) )
    +
  #  BOB PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'BOB'] * 
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX BOB$/US$', 'Value' ) )
        +
  #  CAD PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'CAD'] *
      (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX CAD$/US$', 'Value' ) )

            +
  #  TRY PARA BRL  
  ['ALL.D.Currency':'ALL.D.Currency':'TRY'] *
      (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX TRY$/US$', 'Value' ) )

      +
    # UYU PARA BRL
  ['ALL.D.Currency':'ALL.D.Currency':'UYU'] * 
    
    (DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )   \
     DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX UYU$/US$', 'Value' ) )
    ;




###############################################################
#-------------------------------------# EUR CONV #-----------------------------------------
###############################################################


#-------------------------------------# VALOR INICIAL  #-----------------------------------------
  ['ALL.D.Currency':'ALL.D.Currency':'EUR Conv.' , 'DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt': { 'Initial Gross Debt' ,   'Initial Gross Debt Leasing' } ] = N:
#EUR     
  ['ALL.D.Currency':'ALL.D.Currency':'EUR']
     +
   # USD PARA EUR  
  ['ALL.D.Currency':'ALL.D.Currency':'USD'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX R$/US$', 'Value' )
       +
    # BRL PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'BRL']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX R$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX US$/EUR', 'Value' )
 )

       +
    # ARS PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'ARS']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX ARS$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX US$/EUR', 'Value' )
 )

           +
    # BOB PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'BOB']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX BOB$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX US$/EUR', 'Value' )
 )

               +
    # CAD PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'CAD']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX CAD$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Average FX US$/EUR', 'Value' )
 )
               +
    # TRY PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'TRY']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX TRY$/US$', 'Value' ) )
 \DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX US$/EUR', 'Value' )
 )

                   +
    # UYU PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'UYU']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX UYU$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Initial FX US$/EUR', 'Value' )
 )
    
    ;


#-------------------------------------# VALOR FINAL  #-----------------------------------------
  ['ALL.D.Currency':'ALL.D.Currency':'EUR Conv.' , 'DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':{ 'Closing Balance Debt' , 'Closing Balance Debt Leasing'}  ] = N: 
#EUR     
  ['ALL.D.Currency':'ALL.D.Currency':'EUR']
     +
   # USD PARA EUR  
  ['ALL.D.Currency':'ALL.D.Currency':'USD'] \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' )
       +
    # BRL PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'BRL']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX R$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
 )

       +
    # ARS PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'ARS']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX ARS$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
 )

           +
    # BOB PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'BOB']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX BOB$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
 )

               +
    # CAD PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'CAD']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX CAD$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
 )
               +
    # TRY PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'TRY']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX TRY$/US$', 'Value' ) )
 \DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
 )

                   +
    # UYU PARA EUR  
 ( 
   ( ['ALL.D.Currency':'ALL.D.Currency':'UYU']  \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX UYU$/US$', 'Value' ) )
 \ DB( 'ALL.010.Economic_Assumptions', !ALL.D.Year, !ALL.D.Month, !ALL.D.Version, 'Ending FX US$/EUR', 'Value' )
 )
    
    ;



# --------------------------------------------------------------------------------------------
#
#                      			INICIO DO BLOCO CALCULOS DÍVIDA
#
# --------------------------------------------------------------------------------------------




# --------------------------------------------------------------------------------------------
# Name: Initial Gross Debt
# Desc: Initial Gross Debt
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.M.180.Gross_Debt':'DFS.M.180.Gross_Debt':'Value' , 'DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Initial Gross Debt']=N:
    DB('STG.100.DataBase_Uploads', 
     !ALL.D.Year, 
     !ALL.D.Month,
     !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     'ALL.D.Products':'Total Products',
     'INITIAL GROSS DEBT (LC)',
      'ALL.D.Account_Line':'Total Accounts Line', 
     'Value'
)
  
  +

  DB( 'DFS.180.Gross_Debt', 
      DB( 'SYS.200.Time_Travel', !ALL.D.Year, !ALL.D.Month, '-1', 'Ano' )  ,
      DB( 'SYS.200.Time_Travel', !ALL.D.Year, !ALL.D.Month, '-1', 'Mes' ) ,
      !ALL.D.Version,
      !ALL.D.Currency,
      !ALL.D.Region,
      'DFS.D.Accounts_Debt':'Closing Balance Debt',
      'DFS.M.180.Gross_Debt':'Total Value'
    )
  
  
  ;

