     !ALL.D.Year, 
     !ALL.D.Month,
     !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     'ALL.D.Products':'Total Products',
     'Monetary Variation (LC)',
      'ALL.D.Account_Line':'Total Accounts Line', 
     'Value'
);


# --------------------------------------------------------------------------------------------
# Name:Principal Amortization
# Desc:Principal Amortization
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
['DFS.M.180.Gross_Debt':'DFS.M.180.Gross_Debt':'Value' , 'DFS.D.Accounts_Debt':'DFS.D.Accounts_Debt':'Principal Amortization']=N:
    DB('STG.100.DataBase_Uploads', 
     !ALL.D.Year, 
     !ALL.D.Month,
     !ALL.D.Version,
     !ALL.D.Currency,
     !ALL.D.Region,
     'ALL.D.Products':'Total Products',
     'Principal Amortization (LC)',
      'ALL.D.Account_Line':'Total Accounts Line', 
     'Value'
);


# --------------------------------------------------------------------------------------------
# Name:Interest Amortization
# Desc:Interest Amortization
# Date 01/2026
# Author: Miranda / Helder
# --------------------------------------------------------------------------------------------
