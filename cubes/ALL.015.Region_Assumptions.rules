# =============
SKIPCHECK;
FEEDSTRINGS;
# =============


# --------------------------------------------------------------------------------------------
# INÍCIO DO BLOCO DE CÁLCULOS
# Cubo: ALL.015.Region_Assumptions
# Objetivo: Cálculo de percentuais e premissas regionais
# --------------------------------------------------------------------------------------------


# --------------------------------------------------------------------------------------------
# % Minoritários
# Fórmula:
# Minority Interests / Net Profit Before Minority Int.
# --------------------------------------------------------------------------------------------
['ALL.D.Region_Assumptions':'ALL.D.Region_Assumptions':'% Minoritários'] = C:

    DB(
        'DFS.100.Profit_and_Loss',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        'ALL.D.Currency':'Total Currency',
        !ALL.D.Region,
        'ALL.D.Products':'Total Products',
        'Minority Interests',
        'Value'
    )
    \
    DB(
        'DFS.100.Profit_and_Loss',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        'ALL.D.Currency':'Total Currency',
        !ALL.D.Region,
        'ALL.D.Products':'Total Products',
        'Net Profit Before Minority Int.',
        'Value'
    );


# --------------------------------------------------------------------------------------------
# % Participation
# Fórmula:
# EBITDA Econômico / EBITDA
# --------------------------------------------------------------------------------------------
['ALL.D.Region_Assumptions':'ALL.D.Region_Assumptions':'% Participation'] = C:

    DB(
        'DFS.100.Profit_and_Loss',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        'ALL.D.Currency':'Total Currency',
        !ALL.D.Region,
        'ALL.D.Products':'Total Products',
        'EBITDA Econômico',
        'Value'
    )
    \
    DB(
        'DFS.100.Profit_and_Loss',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        'ALL.D.Currency':'Total Currency',
        !ALL.D.Region,
        'ALL.D.Products':'Total Products',
        'EBITDA',
        'Value'
    );


# --------------------------------------------------------------------------------------------
# % Income Tax
# Fórmula:
# Income Tax / Base Tributável
# --------------------------------------------------------------------------------------------
['ALL.D.Region_Assumptions':'ALL.D.Region_Assumptions':'% Income Tax'] = C:

    DB(
        'DFS.100.Profit_and_Loss',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        'ALL.D.Currency':'Total Currency',
        !ALL.D.Region,
        'ALL.D.Products':'Total Products',
        'Income Tax',
        'Value'
    )
    \
    (
        DB(
            'DFS.100.Profit_and_Loss',
            !ALL.D.Year,
            !ALL.D.Month,
            !ALL.D.Version,
            'ALL.D.Currency':'Total Currency',
            !ALL.D.Region,
            'ALL.D.Products':'Total Products',
            'EBITDA',
            'Value'
        )

        +

        DB(
            'DFS.100.Profit_and_Loss',
            !ALL.D.Year,
            !ALL.D.Month,
            !ALL.D.Version,
            'ALL.D.Currency':'Total Currency',
            !ALL.D.Region,
            'ALL.D.Products':'Total Products',
            'Other Non Op. Results',
            'Value'
        )

        +

        DB(
            'DFS.100.Profit_and_Loss',
            !ALL.D.Year,
            !ALL.D.Month,
            !ALL.D.Version,
            'ALL.D.Currency':'Total Currency',
            !ALL.D.Region,
            'ALL.D.Products':'Total Products',
            'Depreciation',
            'Value'
        )

        +

        DB(
            'DFS.100.Profit_and_Loss',
            !ALL.D.Year,
            !ALL.D.Month,
            !ALL.D.Version,
            'ALL.D.Currency':'Total Currency',
            !ALL.D.Region,
            'ALL.D.Products':'Total Products',
            'DFS.D.Accounts_PnL':'Financial Results',
            'Value'
        )

        +

        DB(
            'STG.100.DataBase_Uploads',
            !ALL.D.Year,
            !ALL.D.Month,
            !ALL.D.Version,
            'ALL.D.Currency':'Total Currency',
            !ALL.D.Region,
            'ALL.D.Products':'Total Products',
            'Additions/Low IT Income Statement',
            'Total Accounts Line',
            'Value'
        )
    );


# --------------------------------------------------------------------------------------------
# % Rate Over Financial Investments
# Fórmula:
# Tax on Financial Revenue / Receita Financeira Total
# --------------------------------------------------------------------------------------------
['ALL.D.Region_Assumptions':'ALL.D.Region_Assumptions':'% Rate Over Financial Investments'] = C:

    DB(
        'DFS.140.Indirect_Cash_Flow',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        'ALL.D.Currency':'Total Currency',
        !ALL.D.Region,
        'Tax on Financial Revenue',
        'Value'
    )
    \
    (
        DB(
            'DFS.140.Indirect_Cash_Flow',
            !ALL.D.Year,
            !ALL.D.Month,
            !ALL.D.Version,
            'ALL.D.Currency':'Total Currency',
            !ALL.D.Region,
            'Financial Revenue',
            'Value'
        )

        +

        DB(
            'STG.100.DataBase_Uploads',
            !ALL.D.Year,
            !ALL.D.Month,
            !ALL.D.Version,
            'ALL.D.Currency':'Total Currency',
            !ALL.D.Region,
            'ALL.D.Products':'Total Products',
            'Additions/Low IT Income Statement',
            'Total Accounts Line',
            'Value'
        )
    );


# --------------------------------------------------------------------------------------------
# % Caixa Invested
# Fórmula:
# Invested Cash / Initial Cash Balance
# --------------------------------------------------------------------------------------------
['ALL.D.Region_Assumptions':'ALL.D.Region_Assumptions':'% Caixa Invested'] = C:

    DB(
        'DFS.140.Indirect_Cash_Flow',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        'ALL.D.Currency':'Total Currency',
        !ALL.D.Region,
        'Invested Cash',
        'Value'
    )
    \
    DB(
        'DFS.140.Indirect_Cash_Flow',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        'ALL.D.Currency':'Total Currency',
        !ALL.D.Region,
        'Initial Cash Balance',
        'Value'
    );


# --------------------------------------------------------------------------------------------
# % Cash Investment Return
# Fórmula:
# Financial Revenue / Invested Cash
# --------------------------------------------------------------------------------------------
['ALL.D.Region_Assumptions':'ALL.D.Region_Assumptions':'% Cash Investment Return'] = C:

    DB(
        'DFS.140.Indirect_Cash_Flow',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        'ALL.D.Currency':'Total Currency',
        !ALL.D.Region,
        'Financial Revenue',
        'Value'
    )
    \
    DB(
        'DFS.140.Indirect_Cash_Flow',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        'ALL.D.Currency':'Total Currency',
        !ALL.D.Region,
        'Invested Cash',
        'Value'
    );


# --------------------------------------------------------------------------------------------
# % Income Tax Theoretical
# Fórmula:
# Income Tax Theoretical / Base Teórica
# --------------------------------------------------------------------------------------------
[
    'ALL.D.Region_Assumptions':'ALL.D.Region_Assumptions':'% Income Tax Theoretical',
    'ALL.M.015.Region_Assumptions':'ALL.M.015.Region_Assumptions':'Value'
] = C:

    DB(
        'DFS.200.KPIs',
        !ALL.D.Year,
        !ALL.D.Month,
        !ALL.D.Version,
        'ALL.D.Currency':'Total Currency',
        !ALL.D.Region,
        'ALL.D.Products':'Total Products',
        'Income Tax Theoretical',
        'Value'
    )

    /

    (
        DB(
            'DFS.100.Profit_and_Loss',
            !ALL.D.Year,
            !ALL.D.Month,
            !ALL.D.Version,
            'ALL.D.Currency':'Total Currency',
            !ALL.D.Region,
            'ALL.D.Products':'Total Products',
            'Other Op. Results',
            'Total Value'
        )

        +

        DB(
            'DFS.100.Profit_and_Loss',
            !ALL.D.Year,
            !ALL.D.Month,
            !ALL.D.Version,
            'ALL.D.Currency':'Total Currency',
            !ALL.D.Region,
            'ALL.D.Products':'Total Products',
            'Financial Results',
            'Value'
        )

        +

        DB(
            'STG.100.DataBase_Uploads',
            !ALL.D.Year,
            !ALL.D.Month,
            !ALL.D.Version,
            'ALL.D.Currency':'Total Currency',
            !ALL.D.Region,
            'ALL.D.Products':'Total Products',
            'Additions/Low IT Income Statement',
            'N/A',
            'Value'
        )
    );