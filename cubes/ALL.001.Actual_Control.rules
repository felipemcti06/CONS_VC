['ALL.D.Version':'ALL.D.Version':'RE' , 'ALL.M.001.Actual_Control':'ALL.M.001.Actual_Control':'Flag']=S: 
IF( DB( 'ALL.001.Actual_Control', !ALL.D.Year, !ALL.D.Month, 'T3',!ALL.M.001.Actual_Control )@= 'ACTUAL' 
  %DB( 'ALL.001.Actual_Control', !ALL.D.Year, !ALL.D.Month, 'T3',!ALL.M.001.Actual_Control )@='MONTHLY CLOSING'
  ,'ACTUAL', CONTINUE );

