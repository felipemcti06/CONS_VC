s05 		=  sPeriod ;
s06			=  csRules;
s07			=  NumberToString ( csThreads);
s08			=  csCopyType;
s09			=  csUser;

# ===================================================================================
# REJECTION AND STATUS
# Save records to file
# ===================================================================================
If( nReject = 1  %  csUseDebug @= 'S' );


  # Write the rejected records file header
  # =================================================================================
  If( nRejectHeader = 0);
    #AsciiOutput( sRejectFolderFile , 'Cubo' , 'Dimensão Versão' , 'Dimensão Ano' , 'Dimensão Mês' , 'Dimensão Ano e Mês' , 'Período' , 'Versao Origem' , 'Versao Destino' , 'Mensagem de Erro');
    CellPuts( 'Cube' , csCubeReject , csProcess , 'Header', 'Col_01'); 
    CellPuts( 'Dimension Version' , csCubeReject , csProcess , 'Header', 'Col_02'); 
    CellPuts( 'Dimension Year' , csCubeReject , csProcess , 'Header', 'Col_03'); 
    CellPuts( 'Dimension Month' , csCubeReject , csProcess , 'Header', 'Col_04'); 
    CellPuts( 'Dimension Year and Month' , csCubeReject , csProcess , 'Header', 'Col_05'); 
    CellPuts( 'Period' , csCubeReject , csProcess , 'Header', 'Col_06'); 
    CellPuts( 'Source Version' , csCubeReject , csProcess , 'Header', 'Col_07'); 
    CellPuts( 'Target Version' , csCubeReject , csProcess , 'Header', 'Col_08'); 
    CellPuts( 'Registration Number', csCubeReject , csProcess , 'Header', 'Registration Number'); 
    CellPuts( 'Error Message', csCubeReject , csProcess , 'Header', 'Error Message'); 
    nRejectHeader = 1;
    nErrors = 2;
    sMessageProcess = ' Process completed with rejected records, check cube:    ' | csCubeReject ;
  EndIf;


  # Writes the record to the reject file and skips the record
  # =================================================================================
  vLine = 'Line_' | FILL( '0' , 4 - Long( NumberToString( nRejectCount ) ) ) | NumberTOString( nRejectCount ) ;
  CellPuts(vsCube , csCubeReject  , csProcess , vLine, 'Col_01'); 
  CellPuts(sDimVersion , csCubeReject  , csProcess , vLine, 'Col_02'); 
  CellPuts(sDimYear , csCubeReject , csProcess , vLine, 'Col_03'); 
  CellPuts(sDimMonth , csCubeReject , csProcess , vLine, 'Col_04'); 
  CellPuts(sDimYearMonth , csCubeReject , csProcess , vLine, 'Col_05'); 
  CellPuts(sPeriod , csCubeReject , csProcess , vLine, 'Col_06'); 
  CellPuts(csSourceElement , csCubeReject , csProcess , vLine, 'Col_07'); 
  CellPuts(csTargetElement , csCubeReject , csProcess , vLine, 'Col_08'); 
  CellPuts(sRecordCount , csCubeReject , csProcess , vLine, 'Registration Number'); 
  CellPuts(sMessageRecord , csCubeReject , csProcess , vLine, 'Error Message'); 
  nRejectCount = nRejectCount  + 1 ;

  # =================================================================================
  # Records "fail" log in Control Cube
  # =================================================================================
  CellPutS( s01 , csCubeRecord, vsCube, csTimeStamp,  'StartTime' );
  CellPutS( s02 , csCubeRecord, vsCube, csTimeStamp,  'Message' );
  CellPutS( s03 , csCubeRecord, vsCube, csTimeStamp,  'Source Version' );
  CellPutS( s04 , csCubeRecord, vsCube, csTimeStamp,  'Destination Version' );
  CellPutS( s05 , csCubeRecord, vsCube, csTimeStamp,  'Copy Period' );
  CellPutS( s06 , csCubeRecord, vsCube, csTimeStamp,  'Copy With Rules' );
  CellPutS( s07 , csCubeRecord, vsCube, csTimeStamp,  'Qtd Threads' );
  CellPutS( s08 , csCubeRecord, vsCube, csTimeStamp,  'Copy Type' );
  CellPutS( s09 , csCubeRecord, vsCube, csTimeStamp,  'User' );
  CellPutS( 'Fail' , csCubeRecord, vsCube, csTimeStamp,  'Status' );
  
  CellPutS( s01 , csCubeRecord, vsCube, 'Current Copy',  'StartTime' );
  CellPutS( s02 , csCubeRecord, vsCube, 'Current Copy',  'Message' );
  CellPutS( s03 , csCubeRecord, vsCube, 'Current Copy',  'Source Version' );
  CellPutS( s04 , csCubeRecord, vsCube, 'Current Copy',  'Destination Version' );
  CellPutS( s05 , csCubeRecord, vsCube, 'Current Copy',  'Copy Period' );
  CellPutS( s06 , csCubeRecord, vsCube, 'Current Copy',  'Copy With Rules' );
  CellPutS( s07 , csCubeRecord, vsCube, 'Current Copy',  'Qtd Threads' );
  CellPutS( s08 , csCubeRecord, vsCube, 'Current Copy',  'Copy Type' );
  CellPutS( s09 , csCubeRecord, vsCube, 'Current Copy',  'User' );
  CellPutS( 'Fail' , csCubeRecord, vsCube, 'Current Copy',  'Status' );
  
  #CubeSaveData( csCubeRecord );

  # Clear variables and skip registration
  # ============================
  IF( nReject = 1 );
     nReject = 0;
     sMessageRecord = '';
     nErrors = 2;
     ItemSkip;
  EndIf;

EndIf;


#SubsetDestroy( 'SYS.D.Parallel_Control' ,  'Dependency_' | vsCube );

LogOutput( 'INFO', 'Cubo ' | vsCube );


ExecuteProcess( 'zCTI.001.01.Trigger_Parallel' , 'psCube' , vsCube ) ;

#ExecuteProcess( 'zCTI.001.04.Copy_Validation' , 'psCube' , vsCube ) ;


# Treats Threads parameter
# =========================
pCores	= If ( sDimMonth @= '' & sDimYearMonth @= '', 1 , csThreads ) ;
pCores     = If ( sDimMonth @= '' & sDimYearMonth @= '' & sDimYear @<> '', csThreads, pCores );


# Treats Rules parameter
# =========================
pSuppressRules		= If ( csRules @= 'Sim', 0, 1 );

# =================================================================================
# Calculates charging time
# =================================================================================
nElapsedSeconds = ROUND ((NOW - nInitialTime) / 0.000011574074074074);
cTimeStampFim	= TimSt( Now, '\Y-\m-\d \hh\im\ss' );


# =================================================================================
# Logs "Finished" in the Control Cube 
# =================================================================================
s01 	=  cTimeStampFim ;
s02 	=  'Cube copy completed successfully' ;
s03		=  NumberToString ( nElapsedSeconds ) | 's' ;
s04		=  NumberToString ( pCores ) ;
# =================================================================================
# Ajustes Copia Versao
# 05/2024 - Não gravava o Usuario 
# =================================================================================
s05		=  csUser ;

CellPutS( s01 , csCubeRecord, vsCube, csTimeStamp,  'EndTime' );
CellPutS( s02 , csCubeRecord, vsCube, csTimeStamp,  'Message' );
CellPutS( s03 , csCubeRecord, vsCube, csTimeStamp,  'Copy Time' );
CellPutS( s04 , csCubeRecord, vsCube, csTimeStamp,  'Qty Threads' );
# =================================================================================
# Ajustes Copia Versao
# 05/2024 - Não gravava o Usuario 
# =================================================================================
CellPutS( s05 , csCubeRecord, vsCube, csTimeStamp,  'User' );
CellPutS( 'Finished' , csCubeRecord, vsCube, csTimeStamp,  'Status' );

CellPutS( s01 , csCubeRecord, vsCube, 'Cópia Atual',  'EndTime' );
CellPutS( s02 , csCubeRecord, vsCube, 'Cópia Atual',  'Message' );
CellPutS( s03 , csCubeRecord, vsCube, 'Cópia Atual',  'Copy Time' );
CellPutS( s04 , csCubeRecord, vsCube, 'Cópia Atual',  'Qty Threads' );
# =================================================================================
# Ajustes Copia Versao
# 05/2024 - Não gravava o Usuario 
# =================================================================================
CellPutS( s05 , csCubeRecord, vsCube, 'Current Copy',  'User' );
CellPutS( 'Finished' , csCubeRecord, vsCube, 'Cópia Atual',  'Status' );

#CubeSaveData( csCubeRecord );



# =================================================================================
# Enable cube logging
# =================================================================================
#CellPutS( 'YES', csCubeProperties, vsCube, 'LOGGING' );
#LogOutput( 'Info', csCubeProperties| ' YES ' |  vsCube| ' LOGGING' );
#endregion
#region Epilog
# ===============================================================================================================
#EPILOGCOMMENT        Description: Runs SavedataAll and logs copy status
# ===============================================================================================================


# =================================================================================
# Records Error or Success Log in Control Cube 
# =================================================================================
nElapsedSeconds = ROUND ((NOW - cnStartTime ) / 0.000011574074074074);
If( nErrors = 0 );
   sMessageProcess  = ' Copy completed successfully';
EndIf;

s01 = TimSt( Now, '\Y-\m-\d \hh\im\ss' ) ;
s02 = sMessageProcess ;
s03 = csSourceElement;
s04 = csTargetElement;
s05 = sPeriod;
s06 = csRules;
s07 = NumberToString (csThreads);
s08 = csCopyType;
s09 = NumberToString (nElapsedSeconds) |  's';
# =================================================================================
# Ajustes Copia Versao
# 05/2024 - Não gravava o Usuario 
# =================================================================================
s10 = csUser;

CellPutS( 'Not started' , csCubeParamCopy, 'Valor', 'Status' );

CellPutS( s01 , csCubeRecord, csCubeRecord, csTimeStamp,  'EndTime' );
CellPutS( s02 , csCubeRecord, csCubeRecord, csTimeStamp,  'Message' );
CellPutS( s03 , csCubeRecord, csCubeRecord, csTimeStamp,  'Source Version' );
CellPutS( s04 , csCubeRecord, csCubeRecord, csTimeStamp,  'Destination Version' );
CellPutS( s05 , csCubeRecord, csCubeRecord, csTimeStamp,  'Copy Period' );
CellPutS( s06 , csCubeRecord, csCubeRecord, csTimeStamp,  'Copy With Rules' );
CellPutS( s07 , csCubeRecord, csCubeRecord, csTimeStamp,  'Qtd Threads' );
CellPutS( s08 , csCubeRecord, csCubeRecord, csTimeStamp,  'Copy Type' );
CellPutS( s09 , csCubeRecord, csCubeRecord, csTimeStamp,  'Copy Time' );
# =================================================================================
# Ajustes Copia Versao
# 05/2024 - Não gravava o Usuario 
# =================================================================================
CellPutS( s10 , csCubeRecord, csCubeRecord, csTimeStamp,  'User' );
  
CellPutS( s01 , csCubeRecord, csCubeRecord, 'Current Copy',  'EndTime' );
CellPutS( s02 , csCubeRecord, csCubeRecord, 'Current Copy',  'Message' );
CellPutS( s03 , csCubeRecord, csCubeRecord, 'Current Copy',  'Source Version' );
CellPutS( s04 , csCubeRecord, csCubeRecord, 'Current Copy',  'Destination Version' );
CellPutS( s05 , csCubeRecord, csCubeRecord, 'Current Copy',  'Copy Period' );
CellPutS( s06 , csCubeRecord, csCubeRecord, 'Current Copy',  'Copy With Rules' );
CellPutS( s07 , csCubeRecord, csCubeRecord, 'Current Copy',  'Qtd Threads' );
CellPutS( s08 , csCubeRecord, csCubeRecord, 'Current Copy',  'Copy Type' );
CellPutS( s09 , csCubeRecord, csCubeRecord, 'Current Copy',  'Copy Time' );
# =================================================================================
# Ajustes Copia Versao
# 05/2024 - Não gravava o Usuario 
# =================================================================================
CellPutS( s10 , csCubeRecord, csCubeRecord, 'Current Copy',  'User' );

# Records partial copy status
# ===================================
If( nErrors = 2 );
  CellPutS( 'Partial' , csCubeRecord, csCubeRecord, csTimeStamp,  'Status' );
  CellPutS( 'Partial' , csCubeRecord, csCubeRecord, 'Current Copy',  'Status' );
  ItemReject( sMessageProcess );
EndIf;


# Records Fail copy status
# ===================================
If( nErrors = 1 );
  CellPutS( 'Fail' , csCubeRecord, csCubeRecord, csTimeStamp,  'Status' );
  CellPutS( 'Fail' , csCubeRecord, csCubeRecord, 'Current Copy',  'Status' );
EndIf;


# Records Sucess copy status
# ===================================
If( nErrors <> 1 );
   CellPutS( 'Success' , csCubeRecord, csCubeRecord, csTimeStamp,  'Status' );
   CellPutS( 'Success' , csCubeRecord, csCubeRecord, 'Current Copy',  'Status' );
EndIf;

# Run SaveDataAll
# ===================================
#SaveDataAll;
#endregion