#region Data
# ===============================================================================================================
#DATACOMMENT        Description: Validates the values of each cube trigger, and triggers the version copy of these cubes.
# ===============================================================================================================

# ===================================================================================
# Generates counter for debug file or rejected records and counts the total number of records processed
# ===================================================================================
nRecordCount = nRecordCount + 1;
sRecordCount = NumberToString( nRecordCount );

# =================================================================================
# Gets the definition of whether or not this cube should be copied
# =================================================================================
IF( Dimix('}Cubes',vsCube)=0);
  ItemSkip;
EndIF;

# sRunCopy 	= Trim (CellGetS ( csCubeSource , vsCube, psSCenario));
# If ( sRunCopy @<> 'S' & sRunCopy @<> 'Y' );
#   ItemSkip;
# EndIf;

sFlag 	= Trim (CellGetS ( csCubeSource , vsCube, 'Copy Version (Y/N)'));
If ( sFlag @<> 'S' & sFlag @<> 'Y' );
  ItemSkip;
EndIf;
# ===================================================================================
# Removes whitespace from variables
# ===================================================================================
sDimVersion 	= Trim ( CellGetS( csCubeSource , vsCube , 'Dimension Version' ) );
sDimYear		= Trim ( CellGetS( csCubeSource , vsCube , 'Dimension Year' ) );
sDimMonth		= Trim ( CellGetS( csCubeSource , vsCube , 'Dimension Month' ) );
sDimYearMonth	= Trim ( CellGetS( csCubeSource , vsCube , 'Dimension Year and Month' ) );
pDimDriver	= Trim ( CellGetS( csCubeSource , vsCube , 'Dimension Driver' ) );


# ===================================================================================
# Treats variables
# ===================================================================================
sStartYear    = SUBST( csStartDate, 1, 4 ) ;
sStartMonth = SUBST( csStartDate, 5, 2 ) ;

sEndYear    = SUBST( csEndDate, 1, 4 ) ;
sEndMonth = SUBST( csEndDate, 5, 2 ) ;

sDestStartYear    = SUBST( csDestStartDate, 1, 4 ) ;
sDestStartMonth = SUBST( csDestStartDate, 5, 2 ) ;

#Region Validation of Variables

