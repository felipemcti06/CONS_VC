# =================================================================================
# Defines cube copy start variables
# =================================================================================
nInitialTime 		= NOW;
sStartTimeStamp	= TimSt( Now, '\Y-\m-\d \hh\im\ss' );

# =================================================================================
# Records the Log in the Control Cube 
# =================================================================================
sPeriod	=  csStartDate | ' ' | csEndDate;
s01 		=  sStartTimeStamp ;
s02 		=  sMessageRecord;
s03 		=  csSourceElement;
s04 		=  csTargetElement;
s05 		=  sPeriod ;
s06			=  csRules;
s07			=  NumberToString ( csThreads);
s08			=  csCopyType;
s09			=  csUser;

# ===================================================================================
# REJECTION AND STATUS
# Save records to file
# ===================================================================================
If( nReject = 1  %  csUseDebug @= 'S' );
    nReject = 0 ;
     ItemSkip;

EndIf;


# =================================================================================
# Disable cube logging
# =================================================================================
#CellPutS( 'NO', csCubeProperties, vsCube, 'LOGGING' );
