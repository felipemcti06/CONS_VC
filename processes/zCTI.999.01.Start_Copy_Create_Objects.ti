cDimension = 'SYS.M.915.Version_Copy_Log' ;
cDimensionpt = 'SYS.M.915.Registro_Copia_Versao' ;
cDimensiones = 'SYS.M.915.Registro_Copia_Version' ;
cElements = 'Status|StartTime|EndTime|Copy Time|Qty Threads|Message|Source Version|Destination Version|Copy Period|Copy With Rules|Copy Type|User|Validation Status' ;
cTypes = 'SSSSSSSSSSSSS' ;


IF( DimensionExists( cDimension)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimension) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimension | ' already exists in the system' ) ;
  endIF;
endIF;

IF( DimensionExists( cDimensionpt)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimensionpt) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimensionpt | ' already exists in the system' ) ;
  endIF;
endIF;

IF( DimensionExists( cDimensiones)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimensiones) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimensiones | ' already exists in the system' ) ;
  endIF;
endIF;
IF(nExists=0);
  DimensionCreate( cDimension );

  nIterations = 1;
  while(cElements@<>'') ;
    cSep = Scan('|', cElements);
    cElement = subst( cElements , 1 , if( cSep=0, long(cElements), cSep-1));
    cElements = subst( cElements, IF(cSep=0, Long(cElements), cSep)+1, Long(cElements) );
    IF( DimensionElementExists( cDimension, cElement )=0);
      DimensionElementInsert( cDimension, '', cElement, Subst(cTypes, nIterations, 1) );
    endIF;
    nIterations = nIterations + 1;
  end;
endIF;

IF( CubeExists(cCube)=1);
  IF(
  CubeDimensionCountGet( cCube )<>3
  %
  TABDIM(cCube, 1)@<>'}Cubes'
  %
  TABDIM(cCube, 2)@<>'SYS.D.Timestamp'
  %
  TABDIM(cCube, 3)@<>'SYS.M.915.Version_Copy_Log'
  ) ;
  CubeDestroy( cCube );
  endIF;
endIF;
IF( CubeExists( cCube )=0);
  CubeCreate( cCube, '}Cubes', 'SYS.D.Timestamp','SYS.M.915.Version_Copy_Log' );
else;
  nExists = nExists + 1;
  LogOutput( 'Info', 'The Cube ' | cCube | ' already exists in the system' ) ;
endIF;


