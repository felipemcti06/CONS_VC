#EndRegion 
#=========================================================================


cDimension = 'SYS.D.Cube' ;
cDimensionpt = 'SYS.D.Cubo' ;
cDimensiones = 'SYS.D.Cube' ;
#cElements = 'Valor' ;
#cTypes = 'N' ;

IF( DimensionExists( cDimension)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimension) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimension | ' already exists in the system' ) ;
  endIF;
endIF;

IF( DimensionExists( cDimensionpt)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimensionpt) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimensionpt | ' already exists in the system' ) ;
  endIF;
endIF;

IF( DimensionExists( cDimensiones)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimensiones) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimensiones | ' already exists in the system' ) ;
  endIF;
endIF;

IF(nExists=0);
  DimensionCreate( cDimension );
  nLen = Dimsiz('}Cubes');
  nIterations = 1;
  while(nIterations<=nLen) ;
    cElement = DimNm('}Cubes',nIterations);
    IF( DimensionElementExists( cDimension, cElement )=0);
      DimensionElementInsert( cDimension, '', cElement, 'N' );
    endIF;
    nIterations = nIterations + 1;
  end;
ENDIF;

cDimension = 'SYS.M.910.Version_Copy_Cube' ;
cDimensionpt = 'SYS.M.910.Cubo_Copia_Versao' ;
cDimensiones = 'SYS.M.910.Cubo_Copia_Version' ;
cElements = 'Copy Version (Y/N)|Copy Version(Y/N) Scenario 1|Copy Version(Y/N) Scenario 2|Copy Version(Y/N) Scenario 3|Dimension Version|Dimension Year|Dimension Month|Dimension Year and Month|Dimension Driver|Copy Priority' ;
cTypes = 'SSSSSSSSSN' ;

IF( DimensionExists( cDimension)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimension) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimension | ' already exists in the system' ) ;
  endIF;
endIF;

IF( DimensionExists( cDimensionpt)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimensionpt) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimensionpt | ' already exists in the system' ) ;
  endIF;
endIF;

IF( DimensionExists( cDimensiones)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimensiones) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimensiones | ' already exists in the system' ) ;
  endIF;
endIF;

IF(nExists=0);
  DimensionCreate( cDimension );

   nIterations = 1;
  while(cElements@<>'') ;
    cSep = Scan('|', cElements);
    cElement = subst( cElements , 1 , if( cSep=0, long(cElements), cSep-1));
    cElements = subst( cElements, IF(cSep=0, Long(cElements), cSep)+1, Long(cElements) );
    IF( DimensionElementExists( cDimension, cElement )=0);
      DimensionElementInsert( cDimension, '', cElement, Subst(cTypes, nIterations, 1) );
    endIF;
    nIterations = nIterations + 1;
  end;
endIF;


IF( CubeExists(cCube)=1);
  IF(
  CubeDimensionCountGet( cCube )<>2
  %
  TABDIM(cCube, 1)@<>'SYS.D.Cube'
  %
  TABDIM(cCube, 2)@<>'SYS.M.910.Version_Copy_Cube'
  ) ;
  CubeDestroy( cCube );
  endIF;
endIF;
IF( CubeExists( cCube )=0);
  CubeCreate( cCube, 'SYS.D.Cube', 'SYS.M.910.Version_Copy_Cube' );
else;
  nExists = nExists + 1;
  LogOutput( 'Info', 'The Cube ' | cCube | ' already exists in the system' ) ;
endIF;


