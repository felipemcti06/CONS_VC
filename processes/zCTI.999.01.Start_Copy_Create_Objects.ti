#=========================================================================
#Region Element Attributes
#DESCRIPTION Dimension: SYS.D.Version_Copy_Rejects
#AUTHOR 
#=========================================================================
#>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>

IF(CubeExists( '}LocalizedElementAttributes_SYS.D.Version_Copy_Rejects' ) = 1);

  CellPutS( 'Cabeçalho', '}LocalizedElementAttributes_SYS.D.Version_Copy_Rejects', 'Header', 'pt', 'Caption' );
  CellPutS( 'Encabezado', '}LocalizedElementAttributes_SYS.D.Version_Copy_Rejects', 'Header', 'es' , 'Caption');
  
  nLen = 200;
  nIterations = 1;
  WHILE(nIterations<=nLen) ;
    cElement = 'Line_' | Fill('0', 4-Long(numberToString(nIterations))) | numberToString(nIterations);
    cElementPt = 'Linha_' | Fill('0', 4-Long(numberToString(nIterations))) | numberToString(nIterations);
    cElementEs = 'Línea_' | Fill('0', 4-Long(numberToString(nIterations))) | numberToString(nIterations);
    
    CellPutS( cElementPt, '}LocalizedElementAttributes_SYS.D.Version_Copy_Rejects', cElement, 'pt', 'Caption' );
    CellPutS( cElementEs, '}LocalizedElementAttributes_SYS.D.Version_Copy_Rejects', cElement, 'es', 'Caption' );
    
    nIterations = nIterations + 1;
  END;

ELSE;
    
 AttrPutS('Cabeçalho', 'SYS.D.Version_Copy_Rejects', 'Header', 'Caption', 'pt');
 AttrPutS('Encabezado', 'SYS.D.Version_Copy_Rejects', 'Header', 'Caption', 'es');
 
  nLen = 200;
  nIterations = 1;
  WHILE(nIterations<=nLen) ;
    cElement = 'Line_' | Fill('0', 4-Long(numberToString(nIterations))) | numberToString(nIterations);
    cElementPt = 'Linha_' | Fill('0', 4-Long(numberToString(nIterations))) | numberToString(nIterations);
    cElementEs = 'Línea_' | Fill('0', 4-Long(numberToString(nIterations))) | numberToString(nIterations);
    
    AttrPutS(cElementPt, 'SYS.D.Version_Copy_Rejects', cElement, 'Caption', 'pt');
    AttrPutS(cElementEs, 'SYS.D.Version_Copy_Rejects', cElement, 'Caption', 'es');
    
    nIterations = nIterations + 1;
  END;
 
ENDIF;

 

