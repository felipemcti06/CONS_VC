#DESCRIPTION Dimension:  SYS.M.910.Version_Copy_Cube
#AUTHOR 
#=========================================================================
#>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>

sDimension = 'SYS.M.910.Version_Copy_Cube' ;
cElements = 'Copy Version (Y/N)|Copy Version(Y/N) Scenario 1|Copy Version(Y/N) Scenario 2|Copy Version(Y/N) Scenario 3|Dimension Version|Dimension Year|Dimension Month|Dimension Year and Month|Dimension Driver|Copy Priority' ;
cElementsPt = 'Copia Versão (S/N)|Copia Versão(S/N) Cenário 1|Copia Versão(S/N) Cenário 2|Copia Versão(S/N) Cenário 3|Dimensão Versão|Dimensão Ano|Dimensão Mês|Dimensão Ano e Mês|Dimensão de Driver|Prioridade na Cópia' ;
cElementsEs = 'Copiar versión (S/N)|Copiar versión (S/N) Escenario 1|Copiar versión (S/N) Escenario 2|Copiar versión (S/N) Escenario 3|Versión de dimensión|Año de dimensión|Mes de dimensión|Año y Mes de dimensión|Driver dimensión|Prioridad de copia' ;



nIterations = 1;
while(cElements@<>'') ;
  cSep = Scan('|', cElements);
  cElement = subst( cElements , 1 , if( cSep=0, long(cElements), cSep-1));
  cElements = subst( cElements, IF(cSep=0, Long(cElements), cSep)+1, Long(cElements) );
  
  cSep = Scan('|', cElementsPt);
  cElementPt = subst( cElementsPt , 1 , if( cSep=0, long(cElementsPt), cSep-1));
  cElementsPt = subst( cElementsPt, IF(cSep=0, Long(cElementsPt), cSep)+1, Long(cElementsPt) );
  
  cSep = Scan('|', cElementsEs);
  cElementEs = subst( cElementsEs , 1 , if( cSep=0, long(cElementsEs), cSep-1));
  cElementsEs = subst( cElementsEs, IF(cSep=0, Long(cElementsEs), cSep)+1, Long(cElementsEs) );
  
  AttrPutS(cElementPt, sDimension, cElement, 'Caption', 'pt');
  AttrPutS(cElementEs, sDimension, cElement, 'Caption', 'es');
  nIterations = nIterations + 1;
end;


