cDimension = 'SYS.M.925.Copy_Validation' ;
cDimensionpt = 'SYS.M.925.Validacao_Copia' ;
cDimensiones = 'SYS.M.925.Validacion_Copia' ;
cElements = 'Type|Dim 1|Dim 2|Dim 3|Dim 4|Dim 5|Dim 6|Dim 7|Dim 8|Dim 9|Dim 10|Dim 11|Dim 12|Dim 13|Dim 14|Dim 15|Dim 16|Dim 17|Dim 18|Dim 19|Dim 20|Dim 21|Dim 22|Dim 23|Dim 24|Dim 25|Dim 26|Dim 27|Dim 28|Dim 29|Dim 30|Dim 31|Dim 32|Dim 33|Dim 34|Dim 35|Dim 36|Dim 37|Dim 38|Dim 39|Dim 40|Dim 41|Result|Message ' ;
cTypes = 'SSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSNS' ;

IF( DimensionExists( cDimension)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimension) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimension | ' already exists in the system' ) ;
  endIF;
endIF;

IF( DimensionExists( cDimensionpt)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimensionpt) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimensionpt | ' already exists in the system' ) ;
  endIF;
endIF;

IF( DimensionExists( cDimensiones)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimensiones) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimensiones | ' already exists in the system' ) ;
  endIF;
endIF;
IF(nExists=0);
 DimensionCreate( cDimension );

  nIterations = 1;
  while(cElements@<>'') ;
   cSep = Scan('|', cElements);
   cSep = if( cSep=0, long(cElements), cSep);
   cElement = subst( cElements , 1 , if( cSep=0, long(cElements), cSep-1));
   cElements = subst( cElements, IF(cSep=0, Long(cElements), cSep)+1, Long(cElements) );
   IF( DimensionElementExists( cDimension, cElement )=0);
     DimensionElementInsert( cDimension, '', cElement, Subst(cTypes, nIterations, 1) );
   endIF;
   nIterations = nIterations + 1;
  end;
endIF;

IF( CubeExists(cCube)=1);
 IF(
 CubeDimensionCountGet( cCube )<>4
 %
 TABDIM(cCube, 1)@<>'SYS.D.Cube'
 %
 TABDIM(cCube, 2)@<>'SYS.D.Validation_Version'
 %
 TABDIM(cCube, 3)@<>'SYS.D.Validation_Parameter'
 %
 TABDIM(cCube, 4)@<>'SYS.M.925.Copy_Validation'
 ) ;
 CubeDestroy( cCube );
 endIF;
endIF;
IF( CubeExists( cCube )=0);
 CubeCreate( cCube, 'SYS.D.Cube','SYS.D.Validation_Version', 'SYS.D.Validation_Parameter', 'SYS.M.925.Copy_Validation' );
else;
  nExists = nExists + 1;
  LogOutput( 'Info', 'The Cube ' | cCube | ' already exists in the system' ) ;
endIF;

