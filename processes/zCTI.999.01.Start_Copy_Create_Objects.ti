 AttrPutS('static:Direct copy:Export/Import and delete files:Export/Import and keep files:', 'SYS.M.900.Version_Copy_Parameter', 'Copy Type', 'Picklist');
 AttrPutS('static:Cópia direta:Export/Import e apagar arquivos:Export/Import e manter arquivos:', 'SYS.M.900.Version_Copy_Parameter', 'Copy Type', 'Picklist','pt');
 AttrPutS('static:Copia directa:Exportar/Importar y eliminar archivos:Exportar/Importar y conservar archivos:', 'SYS.M.900.Version_Copy_Parameter', 'Copy Type', 'Picklist','es');


 AttrPutS('Start Period (Required)', 'SYS.M.900.Version_Copy_Parameter', 'Start Period', 'Description');
 AttrPutS('End Period (Required)', 'SYS.M.900.Version_Copy_Parameter', 'End Period', 'Description');
 AttrPutS('Start Period Target (Optional)', 'SYS.M.900.Version_Copy_Parameter', 'Start Period Target', 'Description');
 AttrPutS('Consider Rules (Required)', 'SYS.M.900.Version_Copy_Parameter', 'Consider Rules', 'Description');
 AttrPutS('Qty Threads (Required)', 'SYS.M.900.Version_Copy_Parameter', 'Qty Threads', 'Description');
 AttrPutS('Copy Type (Required)', 'SYS.M.900.Version_Copy_Parameter', 'Copy Type', 'Description');
 AttrPutS('Source Version (Required)', 'SYS.M.900.Version_Copy_Parameter', 'Source Version', 'Description');
 AttrPutS('Target Version (Required)', 'SYS.M.900.Version_Copy_Parameter', 'Target Version', 'Description');
 AttrPutS('ExportArqPath (Required)', 'SYS.M.900.Version_Copy_Parameter', 'ExportArqPath', 'Description');

 AttrPutS('Período Início (Obrigatorio)', 'SYS.M.900.Version_Copy_Parameter', 'Start Period', 'Description', 'pt');
 AttrPutS('Período Fim (Obrigatorio)', 'SYS.M.900.Version_Copy_Parameter', 'End Period', 'Description', 'pt');
 AttrPutS('Início Período Destino (Opcional)', 'SYS.M.900.Version_Copy_Parameter', 'Start Period Target', 'Description', 'pt');
