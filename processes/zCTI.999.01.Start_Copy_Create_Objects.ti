cCube = 'SYS.910.Version_Copy_Cube';
cCubept = 'SYS.910.Cubo_Copia_Versao';
cCubees = 'SYS.910.Cubo_Copia_Version';
if((pDel@='S' % pDel@='Y') & cubeExists(cCube)=1);
