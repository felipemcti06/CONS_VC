if((pDel@='S' % pDel@='Y') & cubeExists(cCubept)=1);
  CubeDestroy(cCubept) ;
endIF;
if((pDel@='S' % pDel@='Y') & cubeExists(cCubees)=1);
  CubeDestroy(cCubees) ;
endIF;

#=========================================================================
#Region Tambien se tiene que eliminar el cubo SYS.925.Copy_Validation
#DESCRIPTION 
#AUTHOR 
#=========================================================================
#>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>

cCubeAux = 'SYS.925.Copy_Validation';
cCubeptAux = 'SYS.925.Validacao_Copia';
cCubeesAux = 'SYS.925.Validacion_Copia';
if((pDel@='S' % pDel@='Y') & cubeExists(cCubeAux)=1);
  CubeDestroy(cCubeAux) ;
endIF;
if((pDel@='S' % pDel@='Y') & cubeExists(cCubeptAux)=1);
  CubeDestroy(cCubeptAux) ;
endIF;
if((pDel@='S' % pDel@='Y') & cubeExists(cCubeesAux)=1);
  CubeDestroy(cCubeesAux) ;
endIF;

