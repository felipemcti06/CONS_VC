#region Prolog
# ===============================================================================================================
#GENERALCOMMENT             Description:     Process That Creates the cubes dimensions and elements from Version Copy
#GENERALCOMMENT             Responsible:   	Vitor Ribeiro
#GENERALCOMMENT             Date:   January/2024
#
#LASTCHANGE                 Alterações:
#LASTCHANGE                 Responsavel Alterações:
# ===============================================================================================================

# ===============================================================================================================
#PROLOGCOMMENT               Description:            Create the cubes dimenions and elements
# ===============================================================================================================

nExists = 0 ;

#=========================================================================
#Region SYS.900.Version_Copy_Parameter
#DESCRIPTION 
#AUTHOR 
#=========================================================================
#>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>

cCube = 'SYS.900.Version_Copy_Parameter';
cCubept = 'SYS.900.Parametro_Copia_Versao';
cCubees = 'SYS.900.Parametro_Copia_Version';
if((pDel@='S' % pDel@='Y') & cubeExists(cCube)=1);
  CubeDestroy(cCube) ;
endIF;
if((pDel@='S' % pDel@='Y') & cubeExists(cCubept)=1);
  CubeDestroy(cCubept) ;
endIF;
if((pDel@='S' % pDel@='Y') & cubeExists(cCubees)=1);
  CubeDestroy(cCubees) ;
endIF;

cDimension = 'SYS.D.Value' ;
cDimensionpt = 'SYS.D.Valor' ;
cDimensiones = 'SYS.D.Valor' ;
cElements = 'Value' ;
cTypes = 'N' ;

IF( DimensionExists( cDimension)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimension) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimension | ' already exists in the system' ) ;
  endIF;
endIF;

IF( DimensionExists( cDimensionpt)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimensionpt) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimensionpt | ' already exists in the system' ) ;
  endIF;
endIF;

IF( DimensionExists( cDimensiones)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimensiones) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimensiones | ' already exists in the system' ) ;
  endIF;
endIF;

IF(nExists=0);
  DimensionCreate( cDimension );
  nIterations = 1;
  while(cElements@<>'') ;
    cSep = Scan('|', cElements);
    cElement = subst( cElements , 1 , if( cSep=0, long(cElements), cSep-1));
    cElements = subst( cElements, IF(cSep=0, Long(cElements), cSep)+1, Long(cElements) );
    IF( DimensionElementExists( cDimension, cElement )=0);
      DimensionElementInsert( cDimension, '', cElement, Subst(cTypes, nIterations, 1) );
    endIF;
    nIterations = nIterations + 1;
  end;

else;
endIF;

cDimension = 'SYS.M.900.Version_Copy_Parameter' ;
cDimensionpt = 'SYS.M.900.Parametro_Copia_Versao' ;
cDimensiones = 'SYS.M.900.Parametro_Copia_Version' ;
cElements = 'Start Period|End Period|Start Period Target|Qty Months|Consider Rules|Qty Threads|Copy Type|Status|Source Version|Target Version|ExportArqPath' ;
cTypes = 'SSSSSNSSSSS' ;

IF( DimensionExists( cDimension)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimension) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimension | ' already exists in the system' ) ;
  endIF;
endIF;

IF( DimensionExists( cDimensionpt)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimensionpt) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimensionpt | ' already exists in the system' ) ;
  endIF;
endIF;

IF( DimensionExists( cDimensiones)=1);
  if(pDel@='S' % pDel@='Y');
    DimensionDestroy(cDimensiones) ;
  else;
    nExists = nExists + 1;
    LogOutput( 'Info', 'The Dimension ' | cDimensiones | ' already exists in the system' ) ;
  endIF;
endIF;
IF(nExists=0);
  DimensionCreate( cDimension );

  nIterations = 1;
  while(cElements@<>'') ;
    cSep = Scan('|', cElements);
    cElement = subst( cElements , 1 , if( cSep=0, long(cElements), cSep-1));
    cElements = subst( cElements, IF(cSep=0, Long(cElements), cSep)+1, Long(cElements) );
    IF( DimensionElementExists( cDimension, cElement )=0);
      DimensionElementInsert( cDimension, '', cElement, Subst(cTypes, nIterations, 1) );
    endIF;
    nIterations = nIterations + 1;
  end;

else;
  nExists = nExists + 1;
  LogOutput( 'Info', 'The Dimension ' | cDimension | ' already exists in the system' ) ;
endIF;

IF( CubeExists(cCube)=1);
  IF(
  CubeDimensionCountGet( cCube )<>2
  %
  TABDIM(cCube, 1)@<>'SYS.D.Value'
  %
  TABDIM(cCube, 2)@<>'SYS.M.900.Version_Copy_Parameter'
  ) ;
  CubeDestroy( cCube );
  endIF;
endIF;
IF( CubeExists( cCube )=0);
  CubeCreate( cCube, 'SYS.D.Value', 'SYS.M.900.Version_Copy_Parameter' );
else;
  nExists = nExists + 1;
  LogOutput( 'Info', 'The Cube ' | cCube | ' already exists in the system' ) ;
endIF;


#<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
