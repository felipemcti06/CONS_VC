  AttrPutS('dimension:ALL.D.Versao', 'SYS.M.900.Version_Copy_Parameter', 'Source Version', 'Picklist');
  AttrPutS('dimension:ALL.D.Versao', 'SYS.M.900.Version_Copy_Parameter', 'Target Version', 'Picklist');
ElseIf(DimensionExists( 'ALL.D.Version' )=1);
  AttrPutS('dimension:ALL.D.Version', 'SYS.M.900.Version_Copy_Parameter', 'Source Version', 'Picklist');
  AttrPutS('dimension:ALL.D.Version', 'SYS.M.900.Version_Copy_Parameter', 'Target Version', 'Picklist');
EndIF;

