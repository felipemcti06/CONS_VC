sDimension = 'SYS.M.900.Version_Copy_Parameter' ;
cElements = 'Start Period|End Period|Start Period Target|Qty Months|Consider Rules|Qty Threads|Copy Type|Status|Source Version|Target Version|ExportArqPath' ;
cElementsPt = 'Período Início|Período Fim|Início Período Destino|Qtd Meses|Considerar Regras|Qtd Threads|Tipo Cópia|Status|Versão Origem|Versão Destino|CaminhoArqExport' ;
cElementsEs='Período de inicio|Período de finalización|Período de inicio de destino|Cantidad de meses|Reglas de consideración|Cantidad de subprocesos|Tipo de copia|Status|Versión de origen|Versión de destino|RutaArcExportación';



nIterations = 1;
while(cElements@<>'') ;
  cSep = Scan('|', cElements);
  cElement = subst( cElements , 1 , if( cSep=0, long(cElements), cSep-1));
  cElements = subst( cElements, IF(cSep=0, Long(cElements), cSep)+1, Long(cElements) );

  cSep = Scan('|', cElementsPt);
  cElementPt = subst( cElementsPt , 1 , if( cSep=0, long(cElementsPt), cSep-1));
  cElementsPt = subst( cElementsPt, IF(cSep=0, Long(cElementsPt), cSep)+1, Long(cElementsPt) );

  cSep = Scan('|', cElementsEs);
  cElementEs = subst( cElementsEs , 1 , if( cSep=0, long(cElementsEs), cSep-1));
  cElementsEs = subst( cElementsEs, IF(cSep=0, Long(cElementsEs), cSep)+1, Long(cElementsEs) );
  
  AttrPutS(cElementPt, sDimension, cElement, 'Caption', 'pt');
  AttrPutS(cElementEs, sDimension, cElement, 'Caption', 'es');
  nIterations = nIterations + 1;
end;

AttrPutS('dimension:SYS.D.Copia_Versao_Ano_Mes', 'SYS.M.900.Version_Copy_Parameter', 'Start Period', 'Picklist');
AttrPutS('dimension:SYS.D.Copia_Versao_Ano_Mes', 'SYS.M.900.Version_Copy_Parameter', 'End Period', 'Picklist');
AttrPutS('dimension:SYS.D.Copia_Versao_Ano_Mes', 'SYS.M.900.Version_Copy_Parameter', 'Start Period Target', 'Picklist');

