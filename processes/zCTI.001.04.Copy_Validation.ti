            sAux41 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 41' );
            nCountVariable = 1;
            While( nCountVariable <= nMax & nError  = 0);
                sElm = Expand( '%' | 'sElm' | NumberToString( nCountVariable ) | '%' ) ;
                sDim = Expand( '%' | 'sDim' | NumberToString( nCountVariable ) | '%' ) ; 
                IF(sElm @<> '' );
                    IF( DIMIX(sDim, sElm) <> 0);
                        IF( DTYPE( sDim, sElm ) @= 'S' );
                            nError = 1;
                            sMessage = 'The element [ ' | sElm | ' ] of dimension [ ' | sDim | ' ] is not numeric';
