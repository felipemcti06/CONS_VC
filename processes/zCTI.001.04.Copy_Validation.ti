#region Epilog
# ===============================================================================================================
# Defines the validation status and writes to the SYS.915.Version_Copy_Log
# ===============================================================================================================

IF( nCheckResult <> 0 );
    csStatus = 'Value Difference';
ElseIF( nError <> 0);
    cStatus = 'No Validation';
Else;
    cStatus = 'Validation Ok';
endif;

CellPutS( cStatus, csCubeRecord, psCube, 'Current copy',  'Validation Status' );
#endregion