                IF(sElm @<> '' );
                    IF( DIMIX(sDim, sElm) <> 0);
                        IF( DTYPE( sDim, sElm ) @= 'S' );
                            nError = 1;
                            sMessage = 'The element [ ' | sElm | ' ] of dimension [ ' | sDim | ' ] is not numeric';
                            CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );
                        EndIF;                
                    Else;
                        nError = 1;
                        sMessage = 'The element [ ' | sElm | ' ] does not exist in dimension [ ' | sDim | ' ]'; 
                        CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );
                    EndIF;
                ElseIF( sDim @<>'' & sElm @= '' );
                    nError = 1;
                    sMessage = 'The dimension parameter [ ' | sDim | ' ] is empty';
                    CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );    
                EndIF;    
                nCountVariable = nCountVariable + 1; 
            End;
            IF( nError = 0 );
                nSourceValue = CellGetN(psCube, sAux1, sAux2, sAux3, sAux4, sAux5, sAux6, sAux7,  sAux8, sAux9, sAux10, sAux11, sAux12, sAux13, sAux14, sAux15, sAux16, sAux17, sAux18, sAux19, sAux20, sAux21, sAux22, sAux23, sAux24, sAux25, sAux26, sAux27, sAux28, sAux29, sAux30, sAux31, sAux32, sAux33, sAux34, sAux35, sAux36, sAux37, sAux38, sAux39, sAux40);
                nTargetValue = CellGetN(psCube, sElm1, sElm2, sElm3, sElm4, sElm5, sElm6, sElm7, sElm8, sElm9, sElm10, sElm11, sElm12, sElm13, sElm14, sElm15, sElm16, sElm17, sElm18, sElm19, sElm20, sElm21, sElm22, sElm23, sElm24, sElm25, sElm26, sElm27, sElm28, sElm29, sElm30, sElm31, sElm32, sElm33, sElm34, sElm35, sElm36, sElm37, sElm38, sElm39, sElm40);
                nValidation = ABS(nSourceValue) - ABS(nTargetValue) ;
                CellPutN( nValidation, csCubeValidation, psCube, csV1, sParameter, 'Result' );
                IF( nValidation <> 0);
                    sMessageValidacao = 'There is a difference in value between versions: [ ' | sSourceVersion | ' | ' | sTargetVersion | ' ]';
                    CellPutS( sMessageValidacao, csCubeValidation, psCube, csV1, sParameter, 'Message');          
                EndIF;
            EndIF;
         EndIF;
