            sAux34 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 34' );
            sAux35 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 35' );
            sAux36 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 36' );
            sAux37 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 37' );
