#region Prolog
# ===============================================================================================================
# Copyright ctiglobal.com Ver 3.0  08/2020
# ===============================================================================================================
# Process for validating the copy of Version SYS.925.Copy_Validation
# ===============================================================================================================
# Process execution General Parameters
# ======================================================
csCubeCopy = 'SYS.900.Version_Copy_Parameter';
csCubeValidation = 'SYS.925.Copy_Validation';
csCubeRecord = 'SYS.915.Registro_Copia_Versao';
sSourceVersion = CellGetS( csCubeCopy , 'Value',  'Source Version' );
sTargetVersion = CellGetS( csCubeCopy , 'Value',  'Target Version');
sTargetPeriod = CellGetS( csCubeCopy , 'Value', 'End Period' );
sTargetMonth = SUBST( sTargetPeriod, 4, 2 );
sTargetYear = SUBST( sTargetPeriod, 1, 4 );

# Versions compared in the validation cube
# ======================================================
csV1 = 'V1';
csV2 = 'V2';

# Process execution Control Parameters
# ======================================================
nError = 0;
csProcess = GetProcessName();
cnStartTime = Now();

# =================================================================================
# Configuring the Destination Cube cleanup view
# =================================================================================
sSkipCalcs	= 'Y';
sSkipZeroes = 'Y'; 
sSkipRule = 'Y';
sTemporaryView	= 'Y';
nTemporaryView	= If( sTemporaryView @= 'Y', 1, 0);

# Defines view name and cleaning subset
# ======================================================
sTargetView	= 'zProcess.' | csProcess | '.' | 'Clean' | '.' | psCube  | '.' | TimSt( cnStartTime, '\Y-\m-\d \hh\im\ss' );
sTargetSubset = sTargetView;

# Creates the view that will be used for cleaning
# ======================================================
ViewCreate( csCubeValidation, sTargetView, nTemporaryView );

# Creates the subsets that will be used to filter the cleaning view
# ======================================================

sDimension	= 'SYS.D.Cubo';
sElement	= psCube;
If( sDimension @<> '');
  SubsetCreate( sDimension, sTargetSubset , nTemporaryView );  
  ViewSubsetAssign( csCubeValidation , sTargetView, sDimension, sTargetSubset );  
  SubsetElementInsert( sDimension, sTargetSubset, sElement	, 1 );
EndIf;

sDimension	= 'SYS.D.Validation_Version';
sElement	= csV1;
If( sDimension @<> '');
  SubsetCreate( sDimension, sTargetSubset , nTemporaryView );  
  ViewSubsetAssign( csCubeValidation , sTargetView, sDimension, sTargetSubset );  
  SubsetElementInsert( sDimension, sTargetSubset, sElement	, 1 );
EndIf;

sDimension	= 'SYS.M.925.Copy_Validation';
sElement1	= 'Result';
sElement2	= 'Message';
If( sDimension @<> '');
  SubsetCreate( sDimension, sTargetSubset , nTemporaryView );  
  ViewSubsetAssign( csCubeValidation , sTargetView, sDimension, sTargetSubset );  
  SubsetElementInsert( sDimension, sTargetSubset, sElement1	, 1 );
   SubsetElementInsert( sDimension, sTargetSubset, sElement2	, 1 );
EndIf;

ViewZeroOut( csCubeValidation , sTargetView );

# ===============================================================================================================
# Loop to count the dimensions of the parameterized cube
# If the first two metrics are without a title, it means that there are not enough dimensions to validate the cube
# ===============================================================================================================
csDimMetric = 'SYS.M.925.Copy_Validation' ;
nCountMetric = DIMSIZ(csDimMetric);
nQtyDim = 0;
nCount = 1;

While( nCount <= nCountMetric & nError = 0);
    sMetric = 'Dim ' |  NumberToString( nCount );
    IF( DIMIX( csDimMetric, sMetric ) <> 0);
        sDim = CellGetS( csCubeValidation, psCube, csV1, 'Title', sMetric ); 
        IF( sDim @<> '' );
             IF(TABDIM( psCube, nCount) @= sDim );
                  nQtyDim = nQtyDim + 1;
             Else;
                   nError = 1;
                   sMessage = 'Check the sequence of [Titles] of dimensions';
                   CellPutS( sMessage, csCubeValidation, psCube, csV1, 'Title', 'Message' );
             EndIF;
         ElseIF( CellGetS( csCubeValidation, psCube, csV1, 'Title', sMetric ) @= '' & nCount <=2 );
             nError = 1;
             sMessage = 'Check the completion of the [Titles] of dimensions';
             CellPutS( sMessage, csCubeValidation, psCube, csV1, 'Title', 'Message' );
         EndIf;
    EndIF; 
    nCount = nCount + 1; 
End;

IF(nError = 0); 
      sDim1 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 1' );
      sDim2 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 2' );
      sDim3 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 3' );
      sDim4 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 4' );
      sDim5 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 5' );
      sDim6 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 6' );
      sDim7 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 7' );
      sDim8 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 8' );
      sDim9 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 9' );
      sDim10 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 10' );
      sDim11 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 11' );
      sDim12 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 12' );
      sDim13 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 13' );
      sDim14 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 14' );
      sDim15 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 15' );
      sDim16 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 16' );
      sDim17 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 17' );
      sDim18 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 18' );
      sDim19 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 19' );
      sDim20 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 20' );
      sDim21 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 21' );
      sDim22 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 22' );
      sDim23 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 23' );
      sDim24 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 24' );
      sDim25 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 25' );
      sDim26 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 26' );
      sDim27 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 27' );
      sDim28 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 28' );
      sDim29 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 29' );
      sDim30 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 30' );
      sDim31 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 31' );
      sDim32 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 32' );
      sDim33 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 33' );
      sDim34 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 34' );
      sDim35 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 35' );
      sDim36 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 36' );
      sDim37 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 37' );
      sDim38 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 38' );
      sDim39 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 39' );
      sDim40 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 40' );
      sDim41 = CellGetS( csCubeValidation, psCube, csV1, 'Title', 'Dim 41' );
EndIF;

# ===============================================================================================================
# Performs validation for each parameter entered
# ===============================================================================================================
csDimMetric = 'SYS.D.Validation_Parameter';
nCountMetric = DIMSIZ(csDimMetric);
nCheckResult = 0;
nCount = 1; 

While(nCount <= nCountMetric & nError = 0);
    sParameter = 'Parameter ' | NumberToString( nCount );
    
    IF( DIMIX( csDimMetric, sParameter ) <> 0 );
        sCheckParameter = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Type');
        
        #Region 2 Dimension
        # ================
        nMax = 2;
        IF( nQtyDim = nMax & sCheckParameter @<>'');
            sElm1 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 1');
            sElm2 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 2');
            sAux1 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 1');
            sAux2 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 2');
            nCountVariable = 1;
            While( nCountVariable <= nMax & nError  = 0);
                sElm = Expand( '%' | 'sElm' | NumberToString( nCountVariable ) | '%' ) ;
                sDim = Expand( '%' | 'sDim' | NumberToString( nCountVariable ) | '%' ) ; 
                IF(sElm @<> '' );
                    IF( DIMIX(sDim, sElm) <> 0);
                        IF( DTYPE( sDim, sElm ) @= 'S' );
                            nError = 1;
                            sMessage = 'The element [ ' | sElm | ' ] of dimension [ ' | sDim | ' ] is not numeric';
                            CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );
                        EndIF;                
                    Else;
                        nError = 1;
                        sMessage = 'The element [ ' | sElm | ' ] does not exist in dimension [ ' | sDim | ' ]'; 
                        CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );
                    EndIF;
                ElseIF( sDim @<>'' & sElm @= '' );
                    nError = 1;
                    sMessage = 'The dimension parameter [ ' | sDim | ' ] is empty';
                    CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );    
                EndIF;    
                nCountVariable = nCountVariable + 1; 
            End;
            IF( nError = 0 );
                nSourceValue = CellGetN(psCube, sAux1, sAux2);
                nTargetValue = CellGetN(psCube, sElm1, sElm2);
                nValidation = ABS(nSourceValue) - ABS(nTargetValue) ;
                CellPutN( nValidation, csCubeValidation, psCube, csV1, sParameter, 'Result' );
                IF( nValidation <> 0);
                    sMessageValidacao = 'There is a difference in value between versions: [ ' | sSourceVersion | ' | ' | sTargetVersion | ' ]';
                    CellPutS( sMessageValidacao, csCubeValidation, psCube, csV1, sParameter, 'Message');          
                EndIF;
            EndIF;
         EndIF;
        #EndRegion
        
        #Region 3 Dimension
        # ================
        nMax = 3;
        IF( nQtyDim = nMax & sCheckParameter @<>'');
            sElm1 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 1');
            sElm2 = CellGetS( csCubeValidation, psCube, csV1,sParameter, 'Dim 2');
            sElm3 = CellGetS( csCubeValidation, psCube, csV1,sParameter, 'Dim 3');
            sAux1 = CellGetS( csCubeValidation, psCube, csV2,sParameter, 'Dim 1');
            sAux2 = CellGetS( csCubeValidation, psCube, csV2,sParameter, 'Dim 2');
            sAux3 = CellGetS( csCubeValidation, psCube, csV2,sParameter, 'Dim 3');
            nCountVariable = 1;
            While( nCountVariable <= nMax & nError  = 0);
                sElm = Expand( '%' | 'sElm' | NumberToString( nCountVariable ) | '%' ) ;
                sDim = Expand( '%' | 'sDim' | NumberToString( nCountVariable ) | '%' ) ; 
                IF(sElm @<> '' );
                    IF( DIMIX(sDim, sElm) <> 0);
                        IF( DTYPE( sDim, sElm ) @= 'S' );
                            nError = 1;
                            sMessage = 'The element [ ' | sElm | ' ] of dimension [ ' | sDim | ' ] is not numeric';
                            CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );
                        EndIF;                
                    Else;
                        nError = 1;
                        sMessage = 'The element [ ' | sElm | ' ] does not exist in dimension [ ' | sDim | ' ]'; 
                        CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );
                    EndIF;
                ElseIF( sDim @<>'' & sElm @= '' );
                    nError = 1;
                    sMessage = 'The dimension parameter [ ' | sDim | ' ] is empty';
                    CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );    
                EndIF;    
                nCountVariable = nCountVariable + 1; 
            End;
            IF( nError = 0 );
                nSourceValue = CellGetN(psCube, sAux1, sAux2, sAux3);
                nTargetValue = CellGetN(psCube, sElm1, sElm2, sElm3);
                nValidation = ABS(nSourceValue) - ABS(nTargetValue) ;
                CellPutN( nValidation, csCubeValidation, psCube, csV1, sParameter, 'Result' );
                IF( nValidation <> 0);
                    sMessageValidacao = 'There is a difference in value between versions: [ ' | sSourceVersion | ' | ' | sTargetVersion | ' ]';
                    CellPutS( sMessageValidacao, csCubeValidation, psCube, csV1, sParameter, 'Message');          
                EndIF;
            EndIF;
         EndIF;
         #EndRegion

        #Region 4 Dimension
        # ================
        nMax = 4;
        IF( nQtyDim = nMax & sCheckParameter @<>'');
            sElm1 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 1');
            sElm2 = CellGetS( csCubeValidation, psCube, csV1,sParameter, 'Dim 2');
            sElm3 = CellGetS( csCubeValidation, psCube, csV1,sParameter, 'Dim 3');
            sElm4 = CellGetS( csCubeValidation, psCube, csV1,sParameter, 'Dim 4');
            sAux1 = CellGetS( csCubeValidation, psCube, csV2,sParameter, 'Dim 1');
            sAux2 = CellGetS( csCubeValidation, psCube, csV2,sParameter, 'Dim 2');
            sAux3 = CellGetS( csCubeValidation, psCube, csV2,sParameter, 'Dim 3');
            sAux4 = CellGetS( csCubeValidation, psCube, csV2,sParameter, 'Dim 4');
            nCountVariable = 1;
            While( nCountVariable <= nMax & nError  = 0);
                sElm = Expand( '%' | 'sElm' | NumberToString( nCountVariable ) | '%' ) ;
                sDim = Expand( '%' | 'sDim' | NumberToString( nCountVariable ) | '%' ) ; 
                IF(sElm @<> '' );
                    IF( DIMIX(sDim, sElm) <> 0);
                        IF( DTYPE( sDim, sElm ) @= 'S' );
                            nError = 1;
                            sMessage = 'The element [ ' | sElm | ' ] of dimension [ ' | sDim | ' ] is not numeric';
                            CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );
                        EndIF;                
                    Else;
                        nError = 1;
                        sMessage = 'The element [ ' | sElm | ' ] does not exist in dimension [ ' | sDim | ' ]'; 
                        CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );
                    EndIF;
                ElseIF( sDim @<>'' & sElm @= '' );
                    nError = 1;
                    sMessage = 'The dimension parameter [ ' | sDim | ' ] is empty';
                    CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );    
                EndIF;    
                nCountVariable = nCountVariable + 1; 
            End;
            IF( nError = 0 );
                nSourceValue = CellGetN(psCube, sAux1, sAux2, sAux3, sAux4);
                nTargetValue = CellGetN(psCube, sElm1, sElm2, sElm3, sElm4);
                nValidation = ABS(nSourceValue) - ABS(nTargetValue) ;
                CellPutN( nValidation, csCubeValidation, psCube, csV1, sParameter, 'Result' );
                IF( nValidation <> 0);
                    sMessageValidacao = 'There is a difference in value between versions: [ ' | sSourceVersion | ' | ' | sTargetVersion | ' ]';
                    CellPutS( sMessageValidacao, csCubeValidation, psCube, csV1, sParameter, 'Message');          
                EndIF;
            EndIF;
         EndIF;
         #EndRegion

        #Region 5 Dimension
        # ================
        nMax = 5;
        IF( nQtyDim = nMax & sCheckParameter @<>'');
            sElm1 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 1');
            sElm2 = CellGetS( csCubeValidation, psCube, csV1,sParameter, 'Dim 2');
            sElm3 = CellGetS( csCubeValidation, psCube, csV1,sParameter, 'Dim 3');
            sElm4 = CellGetS( csCubeValidation, psCube, csV1,sParameter, 'Dim 4');
            sElm5 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 5' );
            sAux1 = CellGetS( csCubeValidation, psCube, csV2,sParameter, 'Dim 1');
            sAux2 = CellGetS( csCubeValidation, psCube, csV2,sParameter, 'Dim 2');
            sAux3 = CellGetS( csCubeValidation, psCube, csV2,sParameter, 'Dim 3');
            sAux4 = CellGetS( csCubeValidation, psCube, csV2,sParameter, 'Dim 4');
            sAux5 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 5' );
            nCountVariable = 1;
            While( nCountVariable <= nMax & nError  = 0);
                sElm = Expand( '%' | 'sElm' | NumberToString( nCountVariable ) | '%' ) ;
                sDim = Expand( '%' | 'sDim' | NumberToString( nCountVariable ) | '%' ) ; 
                IF(sElm @<> '' );
                    IF( DIMIX(sDim, sElm) <> 0);
                        IF( DTYPE( sDim, sElm ) @= 'S' );
                            nError = 1;
                            sMessage = 'The element [ ' | sElm | ' ] of dimension [ ' | sDim | ' ] is not numeric';
                            CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );
                        EndIF;                
                    Else;
                        nError = 1;
                        sMessage = 'The element [ ' | sElm | ' ] does not exist in dimension [ ' | sDim | ' ]'; 
                        CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );
                    EndIF;
                ElseIF( sDim @<>'' & sElm @= '' );
                    nError = 1;
                    sMessage = 'The dimension parameter [ ' | sDim | ' ] is empty';
                    CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );    
                EndIF;    
                nCountVariable = nCountVariable + 1; 
            End;
            IF( nError = 0 );
                nSourceValue = CellGetN(psCube, sAux1, sAux2, sAux3, sAux4, sAux5);
                nTargetValue = CellGetN(psCube, sElm1, sElm2, sElm3, sElm4, sElm5);
                nValidation = ABS(nSourceValue) - ABS(nTargetValue) ;
                CellPutN( nValidation, csCubeValidation, psCube, csV1, sParameter, 'Result' );
                IF( nValidation <> 0);
                    sMessageValidacao = 'There is a difference in value between versions: [ ' | sSourceVersion | ' | ' | sTargetVersion | ' ]';
                    CellPutS( sMessageValidacao, csCubeValidation, psCube, csV1, sParameter, 'Message');          
                EndIF;
            EndIF;
         EndIF;
         #EndRegion

        #Region 6 Dimension
        # ================
        nMax = 6;
        IF( nQtyDim = nMax & sCheckParameter @<>'');
            sElm1 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 1' );
            sElm2 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 2' );
            sElm3 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 3' );
            sElm4 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 4' );
            sElm5 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 5' );
            sElm6 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 6' );
            sAux1 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 1' );
            sAux2 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 2' );
            sAux3 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 3' );
            sAux4 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 4' );
            sAux5 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 5' );
            sAux6 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 6' );
            nCountVariable = 1;
            While( nCountVariable <= nMax & nError  = 0);
                sElm = Expand( '%' | 'sElm' | NumberToString( nCountVariable ) | '%' ) ;
                sDim = Expand( '%' | 'sDim' | NumberToString( nCountVariable ) | '%' ) ; 
                IF(sElm @<> '' );
                    IF( DIMIX(sDim, sElm) <> 0);
                        IF( DTYPE( sDim, sElm ) @= 'S' );
                            nError = 1;
                            sMessage = 'The element [ ' | sElm | ' ] of dimension [ ' | sDim | ' ] is not numeric';
                            CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );
                        EndIF;                
                    Else;
                        nError = 1;
                        sMessage = 'The element [ ' | sElm | ' ] does not exist in dimension [ ' | sDim | ' ]'; 
                        CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );
                    EndIF;
                ElseIF( sDim @<>'' & sElm @= '' );
                    nError = 1;
                    sMessage = 'The dimension parameter [ ' | sDim | ' ] is empty';
                    CellPutS( sMessage, csCubeValidation, psCube, csV1, sParameter, 'Message' );    
                EndIF;    
                nCountVariable = nCountVariable + 1; 
            End;
            IF( nError = 0 );
                nSourceValue = CellGetN(psCube, sAux1, sAux2, sAux3, sAux4, sAux5, sAux6);
                nTargetValue = CellGetN(psCube, sElm1, sElm2, sElm3, sElm4, sElm5, sElm6);
                nValidation = ABS(nSourceValue) - ABS(nTargetValue) ;
                CellPutN( nValidation, csCubeValidation, psCube, csV1, sParameter, 'Result' );
                IF( nValidation <> 0);
                    sMessageValidacao = 'There is a difference in value between versions: [ ' | sSourceVersion | ' | ' | sTargetVersion | ' ]';
                    CellPutS( sMessageValidacao, csCubeValidation, psCube, csV1, sParameter, 'Message');          
                EndIF;
            EndIF;
         EndIF;
         #EndRegion

        #Region 7 Dimension
        # ================
        nMax = 7;
        IF( nQtyDim = nMax & sCheckParameter @<>'');
            sElm1 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 1' );
            sElm2 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 2' );
            sElm3 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 3' );
            sElm4 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 4' );
            sElm5 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 5' );
            sElm6 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 6' );
            sElm7 = CellGetS( csCubeValidation, psCube, csV1, sParameter, 'Dim 7' );
            sAux1 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 1' );
            sAux2 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 2' );
            sAux3 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 3' );
            sAux4 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 4' );
            sAux5 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 5' );
            sAux6 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 6' );
            sAux7 = CellGetS( csCubeValidation, psCube, csV2, sParameter, 'Dim 7' );
            nCountVariable = 1;
            While( nCountVariable <= nMax & nError  = 0);
                sElm = Expand( '%' | 'sElm' | NumberToString( nCountVariable ) | '%' ) ;
                sDim = Expand( '%' | 'sDim' | NumberToString( nCountVariable ) | '%' ) ; 
                IF(sElm @<> '' );
